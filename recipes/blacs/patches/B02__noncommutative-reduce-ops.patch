diff -urN a/dgamn2d_.c b/dgamn2d_.c
--- a/dgamn2d_.c	2026-07-09 15:58:48.787094146 -0700
+++ b/dgamn2d_.c	2026-07-09 18:24:18.972967998 -0700
@@ -263,7 +263,28 @@
    switch(ttop)
    {
    case ' ':         /* use MPI's reduction by default */
+/*
+ *    Under Intel MPI the combine op is declared non-commutative (flag
+ *    0): its shm-optimized reduce path for commutative user-defined ops
+ *    hands the op callback a pointer into the shared-memory cell
+ *    payload that is only 8-byte aligned once the message exceeds the
+ *    short-message cutoff (count<=2 stays on a safe path).  A callback
+ *    whose element type wants 16-byte alignment (e.g. __float128) is
+ *    compiled with aligned SSE loads and faults on that pointer (#GP ->
+ *    SIGSEGV with si_addr=0; observed with Intel MPI 2021.18,
+ *    disassembly-verified).  A non-commutative op is excluded from that
+ *    path and reduces in rank order through properly aligned buffers,
+ *    which is always correct (and makes the summation order
+ *    deterministic).  Other MPI implementations are unaffected (OpenMPI
+ *    4.1.6 verified clean) and keep the commutative declaration and its
+ *    cheaper reduction algorithms.  Intel MPI's mpi.h also defines the
+ *    MPICH_* macros, so the guard keys on I_MPI_* only.
+ */
+#if defined(I_MPI_VERSION) || defined(I_MPI_NUMVERSION)
+      i = 0;
+#else
       i = 1;
+#endif
       if (Mpval(ldia) == -1)
       {
          ierr=MPI_Op_create(BI_dMPI_amn2, i, &BlacComb);
