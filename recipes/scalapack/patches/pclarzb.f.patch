      $                      WORK( IPW+ICOFFV*LW ), LW )
             ELSE
-               CALL CLAMOV( 'All', K, MQV, V( IOFFV ), LDV,
+               CALL CLAMOV( 'All', K, NQV, V( IOFFV ), LDV,
      $                      WORK( IPW ), LW )
             END IF
          END IF
