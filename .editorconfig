root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{c,h,cpp,hpp,cc}]
indent_style = space
indent_size = 4

[*.{yaml,yml,json}]
indent_style = space
indent_size = 2

[CMakeLists.txt]
indent_style = space
indent_size = 4

[*.cmake]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

# Vendored sources keep their upstream formatting.
[extern/**]
insert_final_newline = unset
trim_trailing_whitespace = unset
