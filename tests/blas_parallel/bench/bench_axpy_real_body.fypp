#! Wall-clock bench — real AXPY: y := alpha*x + y. FLOPs = 2*N per call.

program bench_${routine}$
    use fuzz_util, only: rk, fill_matrix_real
    implicit none

    interface
        subroutine ${routine}$(n, alpha, x, incx, y, incy)
            import :: rk
            integer, intent(in) :: n, incx, incy
            real(rk), intent(in) :: alpha
            real(rk), intent(in) :: x(*)
            real(rk), intent(inout) :: y(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(n, alpha, x, incx, y, incy)
            import :: rk
            integer, intent(in) :: n, incx, incy
            real(rk), intent(in) :: alpha
            real(rk), intent(in) :: x(*)
            real(rk), intent(inout) :: y(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: iters, warmup, nsizes, i
    integer, allocatable :: sizes(:)
    real(rk), allocatable :: X(:), Y(:)
    real(rk) :: alpha
    real(8) :: t_subject, t_mig
    character(len=256) :: out_path
    integer :: ios, jio

    iters  = read_int_env('BLAS_BENCH_ITERS',  4)
    warmup = read_int_env('BLAS_BENCH_WARMUP', 1)
    call read_sizes(sizes); nsizes = size(sizes)
    call get_environment_variable('BLAS_BENCH_OUT', out_path, status=ios)
    if (ios /= 0 .or. len_trim(out_path) == 0) out_path = 'bench_${routine}$.json'
    open(newunit=jio, file=trim(out_path), action='write', status='replace')
    write(jio, '(a)') '{}'; close(jio)

    alpha = 0.7_rk
    print '(a)', '   N         subject GF/s   migrated GF/s   speedup'
    do i = 1, nsizes
        call run_size(sizes(i), alpha, iters, warmup, t_subject, t_mig)
        call emit_console(sizes(i), t_subject, t_mig)
    end do

contains

    function read_int_env(name, dflt) result(v)
        character(len=*), intent(in) :: name
        integer, intent(in) :: dflt
        integer :: v, ios
        character(len=64) :: buf
        v = dflt
        call get_environment_variable(name, buf, status=ios)
        if (ios == 0 .and. len_trim(buf) > 0) then
            read(buf, *, iostat=ios) v
            if (ios /= 0) v = dflt
        end if
    end function read_int_env

    subroutine read_sizes(arr)
        integer, allocatable, intent(out) :: arr(:)
        character(len=256) :: buf
        integer :: ios, i, j, n, val
        character(len=32) :: tok
        call get_environment_variable('BLAS_BENCH_SIZES', buf, status=ios)
        if (ios /= 0 .or. len_trim(buf) == 0) then
            arr = [256, 4096]; return
        end if
        n = 1
        do i = 1, len_trim(buf)
            if (buf(i:i) == ',') n = n + 1
        end do
        allocate(arr(n)); j = 1; tok = ''; n = 0
        do i = 1, len_trim(buf) + 1
            if (i > len_trim(buf) .or. buf(i:i) == ',') then
                read(tok, *, iostat=ios) val
                if (ios == 0) then; n = n + 1; arr(n) = val; end if
                tok = ''; j = 1
            else
                tok(j:j) = buf(i:i); j = j + 1
            end if
        end do
        if (n < size(arr)) arr = arr(1:n)
    end subroutine read_sizes

    subroutine run_size(s, alpha, iters, warmup, t_subject, t_mig)
        integer, intent(in) :: s, iters, warmup
        real(rk), intent(in) :: alpha
        real(8), intent(out) :: t_subject, t_mig
        integer :: it
        real(8), allocatable :: samp_ov(:), samp_mig(:)
        real(8) :: t0, t1
        allocate(X(s), Y(s), samp_ov(iters), samp_mig(iters))
        call fill_matrix_real(X, s, 1, s); call fill_matrix_real(Y, s, 1, s)
        do it = 1, warmup
            call ${routine}$(s, alpha, X, 1, Y, 1)
            call ${routine}$_migrated(s, alpha, X, 1, Y, 1)
        end do
        do it = 1, iters
            call cpu_clock(t0); call ${routine}$(s, alpha, X, 1, Y, 1); call cpu_clock(t1)
            samp_ov(it) = t1 - t0
            call cpu_clock(t0); call ${routine}$_migrated(s, alpha, X, 1, Y, 1); call cpu_clock(t1)
            samp_mig(it) = t1 - t0
        end do
        t_subject = median(samp_ov); t_mig = median(samp_mig)
        deallocate(X, Y, samp_ov, samp_mig)
    end subroutine run_size

    subroutine cpu_clock(t)
        real(8), intent(out) :: t
        integer(8) :: c, r
        call system_clock(count=c, count_rate=r); t = real(c, 8) / real(r, 8)
    end subroutine cpu_clock

    function median(x) result(m)
        real(8), intent(in) :: x(:)
        real(8) :: m
        real(8), allocatable :: y(:)
        integer :: i, j, n
        real(8) :: tmp
        n = size(x); allocate(y(n)); y = x
        do i = 1, n - 1; do j = i + 1, n
            if (y(j) < y(i)) then; tmp = y(i); y(i) = y(j); y(j) = tmp; end if
        end do; end do
        if (mod(n, 2) == 1) then; m = y((n + 1) / 2)
        else; m = 0.5_8 * (y(n / 2) + y(n / 2 + 1)); end if
    end function median

    function gflops(s, t) result(g)
        integer, intent(in) :: s
        real(8), intent(in) :: t
        real(8) :: g
        if (t > 0.0_8) then; g = 2.0_8 * real(s, 8) / t / 1.0e9_8
        else; g = 0.0_8; end if
    end function gflops

    subroutine emit_console(s, t_subject, t_mig)
        integer, intent(in) :: s
        real(8), intent(in) :: t_subject, t_mig
        real(8) :: g_ov, g_mig, sp
        g_ov = gflops(s, t_subject); g_mig = gflops(s, t_mig)
        if (t_subject > 0.0_8) then; sp = t_mig / t_subject; else; sp = 0.0_8; end if
        print '(i8,4x,f12.4,4x,f12.4,4x,f7.2,a)', s, g_ov, g_mig, sp, 'x'
    end subroutine emit_console

end program bench_${routine}$
