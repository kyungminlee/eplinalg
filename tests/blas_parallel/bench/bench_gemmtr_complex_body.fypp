#! Wall-clock bench — complex GEMMTR. Per-target shim sets:
#!   routine    e.g. 'ygemmtr' (kind10), 'xgemmtr' (kind16)

program bench_${routine}$
    use fuzz_util, only: rk, fill_matrix_complex
    implicit none

    interface
        subroutine ${routine}$(uplo, transa, transb, n, k, alpha, a, lda, &
                               b, ldb, beta, c, ldc)
            import :: rk
            character, intent(in) :: uplo, transa, transb
            integer,   intent(in) :: n, k, lda, ldb, ldc
            complex(rk), intent(in) :: alpha, beta
            complex(rk), intent(in) :: a(lda, *), b(ldb, *)
            complex(rk), intent(inout) :: c(ldc, *)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, transa, transb, n, k, alpha, a, lda, &
                                        b, ldb, beta, c, ldc)
            import :: rk
            character, intent(in) :: uplo, transa, transb
            integer,   intent(in) :: n, k, lda, ldb, ldc
            complex(rk), intent(in) :: alpha, beta
            complex(rk), intent(in) :: a(lda, *), b(ldb, *)
            complex(rk), intent(inout) :: c(ldc, *)
        end subroutine ${routine}$_migrated
    end interface

    integer :: iters, warmup, nsizes
    integer, allocatable :: sizes(:)
    complex(rk), allocatable :: A(:), B(:), C(:)
    complex(rk) :: alpha, beta
    character(len=256) :: out_path
    integer :: ios, jio

    iters  = read_int_env('BLAS_BENCH_ITERS',  2)
    warmup = read_int_env('BLAS_BENCH_WARMUP', 1)
    call read_sizes(sizes)
    nsizes = size(sizes)
    call get_environment_variable('BLAS_BENCH_OUT', out_path, status=ios)
    if (ios /= 0 .or. len_trim(out_path) == 0) out_path = 'bench_${routine}$.json'

    alpha = cmplx(0.7_rk, 0.1_rk, rk)
    beta  = cmplx(0.3_rk, 0.2_rk, rk)

    open(newunit=jio, file=trim(out_path), action='write', status='replace')
    write(jio, '(a)') '{'
    write(jio, '(3a)') '  "test": "bench_${routine}$",'
    write(jio, '(a,i0,a)') '  "iters": ', iters, ','
    write(jio, '(a,i0,a)') '  "warmup": ', warmup, ','
    write(jio, '(a)') '  "results": ['

    print '(a)', 'ulo trans  size       subject GFLOP/s   migrated GFLOP/s   speedup'
    call run_combos(sizes, alpha, beta, iters, warmup, jio)

    write(jio, '(a)') '  ]'
    write(jio, '(a)') '}'
    close(jio)
    print '(2a)', 'wrote ', trim(out_path)

contains

    function read_int_env(name, dflt) result(v)
        character(len=*), intent(in) :: name
        integer, intent(in) :: dflt
        integer :: v, ios
        character(len=64) :: buf
        v = dflt
        call get_environment_variable(name, buf, status=ios)
        if (ios == 0 .and. len_trim(buf) > 0) then
            read(buf, *, iostat=ios) v
            if (ios /= 0) v = dflt
        end if
    end function read_int_env

    subroutine read_sizes(arr)
        integer, allocatable, intent(out) :: arr(:)
        character(len=256) :: buf
        integer :: ios, i, j, n, val
        character(len=32) :: tok
        call get_environment_variable('BLAS_BENCH_SIZES', buf, status=ios)
        if (ios /= 0 .or. len_trim(buf) == 0) then
            arr = [64, 128, 256, 512]; return
        end if
        n = 1
        do i = 1, len_trim(buf)
            if (buf(i:i) == ',') n = n + 1
        end do
        allocate(arr(n)); j = 1; tok = ''; n = 0
        do i = 1, len_trim(buf) + 1
            if (i > len_trim(buf) .or. buf(i:i) == ',') then
                read(tok, *, iostat=ios) val
                if (ios == 0) then; n = n + 1; arr(n) = val; end if
                tok = ''; j = 1
            else
                tok(j:j) = buf(i:i); j = j + 1
            end if
        end do
        if (n < size(arr)) arr = arr(1:n)
    end subroutine read_sizes

    subroutine run_combos(sizes, alpha, beta, iters, warmup, jio)
        integer, intent(in) :: sizes(:), iters, warmup, jio
        complex(rk), intent(in) :: alpha, beta
        character(len=1), parameter :: ULS(18) = &
            ['U','U','U','U','U','U','U','U','U','L','L','L','L','L','L','L','L','L']
        character(len=1), parameter :: TAS(18) = &
            ['N','N','N','T','T','T','C','C','C','N','N','N','T','T','T','C','C','C']
        character(len=1), parameter :: TBS(18) = &
            ['N','T','C','N','T','C','N','T','C','N','T','C','N','T','C','N','T','C']
        integer :: itr, idx, nsz, last_idx
        real(8) :: t_subject, t_mig
        nsz = size(sizes); last_idx = 18 * nsz
        do itr = 1, 18
            do idx = 1, nsz
                call run_size(ULS(itr), TAS(itr), TBS(itr), sizes(idx), &
                              alpha, beta, iters, warmup, t_subject, t_mig)
                call emit_json(jio, ULS(itr), TAS(itr), TBS(itr), sizes(idx), &
                               t_subject, t_mig, (itr - 1) * nsz + idx == last_idx)
                call emit_console(ULS(itr), TAS(itr), TBS(itr), sizes(idx), t_subject, t_mig)
            end do
        end do
    end subroutine run_combos

    subroutine run_size(ul, ta, tb, s, alpha, beta, iters, warmup, t_subject, t_mig)
        character(len=1), intent(in) :: ul, ta, tb
        integer, intent(in) :: s, iters, warmup
        complex(rk), intent(in) :: alpha, beta
        real(8), intent(out) :: t_subject, t_mig
        integer :: it
        real(8), allocatable :: samples_ov(:), samples_mig(:)
        real(8) :: t0, t1

        allocate(A(s * s), B(s * s), C(s * s))
        allocate(samples_ov(iters), samples_mig(iters))
        call fill_matrix_complex(A, s, s, s)
        call fill_matrix_complex(B, s, s, s)
        call fill_matrix_complex(C, s, s, s)

        do it = 1, warmup
            call ${routine}$(ul, ta, tb, s, s, alpha, A, s, B, s, beta, C, s)
            call ${routine}$_migrated(ul, ta, tb, s, s, alpha, A, s, B, s, beta, C, s)
        end do
        do it = 1, iters
            call cpu_clock(t0); call ${routine}$(ul, ta, tb, s, s, alpha, A, s, B, s, beta, C, s); call cpu_clock(t1)
            samples_ov(it) = t1 - t0
            call cpu_clock(t0); call ${routine}$_migrated(ul, ta, tb, s, s, alpha, A, s, B, s, beta, C, s); call cpu_clock(t1)
            samples_mig(it) = t1 - t0
        end do
        t_subject = median(samples_ov); t_mig = median(samples_mig)
        deallocate(A, B, C, samples_ov, samples_mig)
    end subroutine run_size

    subroutine cpu_clock(t)
        real(8), intent(out) :: t
        integer(8) :: c, r
        call system_clock(count=c, count_rate=r)
        t = real(c, 8) / real(r, 8)
    end subroutine cpu_clock

    function median(x) result(m)
        real(8), intent(in) :: x(:)
        real(8) :: m
        real(8), allocatable :: y(:)
        integer :: i, j, n
        real(8) :: tmp
        n = size(x); allocate(y(n)); y = x
        do i = 1, n - 1; do j = i + 1, n
            if (y(j) < y(i)) then; tmp = y(i); y(i) = y(j); y(j) = tmp; end if
        end do; end do
        if (mod(n, 2) == 1) then; m = y((n + 1) / 2)
        else; m = 0.5_8 * (y(n / 2) + y(n / 2 + 1)); end if
    end function median

    function gflops(s, t) result(g)
        integer, intent(in) :: s
        real(8), intent(in) :: t
        real(8) :: g
        ! Complex GEMMTR: 8·N²·K / 2 = 4·N²·K real flops (triangle half).
        if (t > 0.0_8) then
            g = 4.0_8 * real(s, 8)**3 / t / 1.0e9_8
        else; g = 0.0_8; end if
    end function gflops

    subroutine emit_console(ul, ta, tb, s, t_subject, t_mig)
        character(len=1), intent(in) :: ul, ta, tb
        integer, intent(in) :: s
        real(8), intent(in) :: t_subject, t_mig
        real(8) :: g_ov, g_mig, speedup
        g_ov = gflops(s, t_subject); g_mig = gflops(s, t_mig)
        if (t_subject > 0.0_8) then; speedup = t_mig / t_subject; else; speedup = 0.0_8; end if
        print '(a1,2x,2a1,3x,i6,4x,f12.4,7x,f12.4,4x,f7.2,a)', &
            ul, ta, tb, s, g_ov, g_mig, speedup, 'x'
    end subroutine emit_console

    subroutine emit_json(io, ul, ta, tb, s, t_subject, t_mig, last)
        integer, intent(in) :: io, s
        character(len=1), intent(in) :: ul, ta, tb
        real(8), intent(in) :: t_subject, t_mig
        logical, intent(in) :: last
        write(io, '(a)') '    {'
        write(io, '(7a)')          '      "uplo": "', ul, '", "transa": "', ta, '", "transb": "', tb, '",'
        write(io, '(a,i0,a)') '      "size": ', s, ','
        write(io, '(a,es16.8,a)') '      "t_overlay_s": ',  t_subject,  ','
        write(io, '(a,es16.8,a)') '      "t_migrated_s": ', t_mig, ','
        write(io, '(a,es16.8,a)') '      "gflops_subject": ',  gflops(s, t_subject),  ','
        write(io, '(a,es16.8)')   '      "gflops_migrated": ', gflops(s, t_mig)
        if (last) then; write(io, '(a)') '    }'; else; write(io, '(a)') '    },'; end if
    end subroutine emit_json

end program bench_${routine}$
