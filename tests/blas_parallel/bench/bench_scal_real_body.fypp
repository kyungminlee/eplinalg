#! Wall-clock bench — real SCAL: x := alpha*x. FLOPs = N per call.

program bench_${routine}$
    use fuzz_util, only: rk, fill_matrix_real
    implicit none
    interface
        subroutine ${routine}$(n, alpha, x, incx)
            import :: rk
            integer, intent(in) :: n, incx
            real(rk), intent(in) :: alpha
            real(rk), intent(inout) :: x(*)
        end subroutine
        subroutine ${routine}$_migrated(n, alpha, x, incx)
            import :: rk
            integer, intent(in) :: n, incx
            real(rk), intent(in) :: alpha
            real(rk), intent(inout) :: x(*)
        end subroutine
    end interface
    integer :: iters, nsizes, i
    integer, allocatable :: sizes(:)
    real(rk), allocatable :: X(:), X0(:)
    real(rk) :: alpha
    real(8) :: t_subject, t_mig
    iters = read_int_env('BLAS_BENCH_ITERS', 4)
    call read_sizes(sizes); nsizes = size(sizes)
    alpha = 0.997_rk  ! != 1 so escal doesn't early-exit
    print '(a)', '   N         subject GF/s   migrated GF/s   speedup'
    do i = 1, nsizes
        call run_size(sizes(i), iters, t_subject, t_mig)
        call emit(sizes(i), t_subject, t_mig)
    end do
contains
    function read_int_env(name, dflt) result(v)
        character(len=*), intent(in) :: name; integer, intent(in) :: dflt; integer :: v, ios; character(len=64) :: buf
        v = dflt; call get_environment_variable(name, buf, status=ios)
        if (ios == 0 .and. len_trim(buf) > 0) then; read(buf, *, iostat=ios) v; if (ios /= 0) v = dflt; end if
    end function
    subroutine read_sizes(arr)
        integer, allocatable, intent(out) :: arr(:); character(len=256) :: buf
        integer :: ios, i, j, n, val; character(len=32) :: tok
        call get_environment_variable('BLAS_BENCH_SIZES', buf, status=ios)
        if (ios /= 0 .or. len_trim(buf) == 0) then; arr = [256, 4096]; return; end if
        n = 1; do i = 1, len_trim(buf); if (buf(i:i) == ',') n = n + 1; end do; allocate(arr(n))
        j = 1; tok = ''; n = 0
        do i = 1, len_trim(buf) + 1
            if (i > len_trim(buf) .or. buf(i:i) == ',') then
                read(tok, *, iostat=ios) val
                if (ios == 0) then; n = n + 1; arr(n) = val; end if
                tok = ''; j = 1
            else; tok(j:j) = buf(i:i); j = j + 1; end if
        end do
        if (n < size(arr)) arr = arr(1:n)
    end subroutine
    subroutine run_size(s, iters, t_subject, t_mig)
        integer, intent(in) :: s, iters; real(8), intent(out) :: t_subject, t_mig
        integer :: it; real(8), allocatable :: so(:), sm(:); real(8) :: t0, t1
        allocate(X(s), X0(s), so(iters), sm(iters))
        call fill_matrix_real(X0, s, 1, s)
        X = X0; call ${routine}$(s, alpha, X, 1)
        X = X0; call ${routine}$_migrated(s, alpha, X, 1)
        do it = 1, iters
            X = X0; call clk(t0); call ${routine}$(s, alpha, X, 1); call clk(t1); so(it) = t1 - t0
            X = X0; call clk(t0); call ${routine}$_migrated(s, alpha, X, 1); call clk(t1); sm(it) = t1 - t0
        end do
        t_subject = med(so); t_mig = med(sm)
        deallocate(X, X0, so, sm)
    end subroutine
    subroutine clk(t)
        real(8), intent(out) :: t; integer(8) :: c, r
        call system_clock(count=c, count_rate=r); t = real(c, 8) / real(r, 8)
    end subroutine
    function med(x) result(m)
        real(8), intent(in) :: x(:); real(8) :: m; real(8), allocatable :: y(:); integer :: i, j, n; real(8) :: tmp
        n = size(x); allocate(y(n)); y = x
        do i = 1, n - 1; do j = i + 1, n; if (y(j) < y(i)) then; tmp = y(i); y(i) = y(j); y(j) = tmp; end if; end do; end do
        if (mod(n, 2) == 1) then; m = y((n + 1) / 2); else; m = 0.5_8 * (y(n / 2) + y(n / 2 + 1)); end if
    end function
    subroutine emit(s, to, tm)
        integer, intent(in) :: s; real(8), intent(in) :: to, tm
        real(8) :: go, gm, sp
        go = real(s, 8) / to / 1.0e9_8; gm = real(s, 8) / tm / 1.0e9_8
        if (to > 0.0_8) then; sp = tm / to; else; sp = 0.0_8; end if
        print '(i8,4x,f12.4,4x,f12.4,4x,f7.2,a)', s, go, gm, sp, 'x'
    end subroutine
end program bench_${routine}$
