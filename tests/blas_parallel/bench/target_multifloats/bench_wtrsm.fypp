! bench_wtrsm — multifloats complex DD triangular solve bench.
!                Sweeps SIDE × UPLO × TRANS × DIAG × sizes.

program bench_wtrsm
    use multifloats
    use fuzz_util, only: fill_matrix_complex
    implicit none

    interface
        subroutine wtrsm(side, uplo, transa, diag, m, n, alpha, &
                         a, lda, b, ldb)
            import :: real64x2, cmplx64x2
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            type(cmplx64x2), intent(in) :: alpha
            type(cmplx64x2), intent(in) :: a(lda, *)
            type(cmplx64x2), intent(inout) :: b(ldb, *)
        end subroutine wtrsm
        subroutine wtrsm_migrated(side, uplo, transa, diag, m, n, alpha, &
                                  a, lda, b, ldb)
            import :: real64x2, cmplx64x2
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            type(cmplx64x2), intent(in) :: alpha
            type(cmplx64x2), intent(in) :: a(lda, *)
            type(cmplx64x2), intent(inout) :: b(ldb, *)
        end subroutine wtrsm_migrated
    end interface

    integer :: iters, warmup, nsizes, i, isd, iup, itr, idg
    integer, allocatable :: sizes(:)
    type(cmplx64x2), allocatable :: A(:), B_init(:), B_use(:)
    type(cmplx64x2) :: alpha
    real(8) :: t_subject, t_mig
    character(len=256) :: out_path
    integer :: ios, jio
    character(len=1), parameter :: SIDES(2)   = ['L', 'R']
    character(len=1), parameter :: UPLOS(2)   = ['L', 'U']
    character(len=1), parameter :: TRANSES(2) = ['N', 'C']
    character(len=1), parameter :: DIAGS(2)   = ['N', 'U']

    iters  = read_int_env('BLAS_BENCH_ITERS',  2)
    warmup = read_int_env('BLAS_BENCH_WARMUP', 1)
    call read_sizes(sizes)
    nsizes = size(sizes)
    call get_environment_variable('BLAS_BENCH_OUT', out_path, status=ios)
    if (ios /= 0 .or. len_trim(out_path) == 0) out_path = 'bench_wtrsm.json'

    alpha = cmplx64x2(real64x2(0.7_8), real64x2(0.0_8))

    open(newunit=jio, file=trim(out_path), action='write', status='replace')
    write(jio, '(a)') '{'
    write(jio, '(a)') '  "test": "bench_wtrsm",'
    write(jio, '(a,i0,a)') '  "iters": ', iters, ','
    write(jio, '(a,i0,a)') '  "warmup": ', warmup, ','
    write(jio, '(a)') '  "results": ['

    print '(a)', 'side uplo trans diag    size      subject GFLOP/s   migrated GFLOP/s   speedup'
    do isd = 1, 2
        do iup = 1, 2
            do itr = 1, 2
                do idg = 1, 2
                    do i = 1, nsizes
                        call run_size(SIDES(isd), UPLOS(iup), TRANSES(itr), DIAGS(idg), &
                                      sizes(i), alpha, iters, warmup, t_subject, t_mig)
                        call emit_json(jio, SIDES(isd), UPLOS(iup), TRANSES(itr), DIAGS(idg), &
                                       sizes(i), t_subject, t_mig, &
                                       isd == 2 .and. iup == 2 .and. itr == 2 .and. idg == 2 .and. i == nsizes)
                        call emit_console(SIDES(isd), UPLOS(iup), TRANSES(itr), DIAGS(idg), sizes(i), t_subject, t_mig)
                    end do
                end do
            end do
        end do
    end do

    write(jio, '(a)') '  ]'
    write(jio, '(a)') '}'
    close(jio)
    print '(2a)', 'wrote ', trim(out_path)

contains

    function read_int_env(name, dflt) result(v)
        character(len=*), intent(in) :: name
        integer, intent(in) :: dflt
        integer :: v, ios
        character(len=64) :: buf
        v = dflt
        call get_environment_variable(name, buf, status=ios)
        if (ios == 0 .and. len_trim(buf) > 0) then
            read(buf, *, iostat=ios) v
            if (ios /= 0) v = dflt
        end if
    end function read_int_env

    subroutine read_sizes(arr)
        integer, allocatable, intent(out) :: arr(:)
        character(len=256) :: buf
        integer :: ios, i, j, n, val
        character(len=32) :: tok
        call get_environment_variable('BLAS_BENCH_SIZES', buf, status=ios)
        if (ios /= 0 .or. len_trim(buf) == 0) then
            arr = [64, 128, 256, 512]; return
        end if
        n = 1
        do i = 1, len_trim(buf); if (buf(i:i) == ',') n = n + 1; end do
        allocate(arr(n))
        j = 1; tok = ''; n = 0
        do i = 1, len_trim(buf) + 1
            if (i > len_trim(buf) .or. buf(i:i) == ',') then
                read(tok, *, iostat=ios) val
                if (ios == 0) then; n = n + 1; arr(n) = val; end if
                tok = ''; j = 1
            else
                tok(j:j) = buf(i:i); j = j + 1
            end if
        end do
        if (n < size(arr)) arr = arr(1:n)
    end subroutine read_sizes

    subroutine fill_tri(M, uplo, diag, A, lda)
        integer, intent(in) :: M, lda
        character, intent(in) :: uplo, diag
        type(cmplx64x2), intent(inout) :: A(:)
        integer :: i, j, idx
        real(8) :: r
        type(real64x2) :: scal
        scal = real64x2(1.0_8 / real(max(M, 1), 8))
        do j = 1, M
            do i = 1, M
                idx = (j - 1) * lda + i
                if ((uplo == 'L' .and. i > j) .or. (uplo == 'U' .and. i < j)) then
                    call random_number(r)
                    A(idx) = cmplx64x2(real64x2(2.0_8*r - 1.0_8) * scal, real64x2(0.0_8))
                else if (i == j) then
                    if (diag == 'U') then
                        A(idx) = cmplx64x2(real64x2(1.0_8), real64x2(0.0_8))
                    else
                        call random_number(r)
                        A(idx) = cmplx64x2(real64x2(1.0_8 + r), real64x2(0.0_8))
                    end if
                else
                    A(idx) = cmplx64x2(real64x2(0.0_8), real64x2(0.0_8))
                end if
            end do
        end do
    end subroutine fill_tri

    subroutine run_size(side, uplo, trans, diag, s, alpha, iters, warmup, t_subject, t_mig)
        character, intent(in) :: side, uplo, trans, diag
        integer, intent(in) :: s, iters, warmup
        type(cmplx64x2), intent(in) :: alpha
        real(8), intent(out) :: t_subject, t_mig
        integer :: it, ma
        real(8), allocatable :: samples_ov(:), samples_mig(:)
        real(8) :: t0, t1

        ! For SIDE='L', A is M×M; for SIDE='R', A is N×N. We use square bench so both = s.
        ma = s
        allocate(A(ma * ma), B_init(s * s), B_use(s * s))
        allocate(samples_ov(iters), samples_mig(iters))
        call fill_tri(ma, uplo, diag, A, ma)
        call fill_matrix_complex(B_init, s, s, s)

        do it = 1, warmup
            B_use = B_init
            call wtrsm(side, uplo, trans, diag, s, s, alpha, A, ma, B_use, s)
            B_use = B_init
            call wtrsm_migrated(side, uplo, trans, diag, s, s, alpha, A, ma, B_use, s)
        end do
        do it = 1, iters
            B_use = B_init
            call cpu_clock(t0)
            call wtrsm(side, uplo, trans, diag, s, s, alpha, A, ma, B_use, s)
            call cpu_clock(t1)
            samples_ov(it) = t1 - t0
            B_use = B_init
            call cpu_clock(t0)
            call wtrsm_migrated(side, uplo, trans, diag, s, s, alpha, A, ma, B_use, s)
            call cpu_clock(t1)
            samples_mig(it) = t1 - t0
        end do
        t_subject  = median(samples_ov)
        t_mig = median(samples_mig)
        deallocate(A, B_init, B_use, samples_ov, samples_mig)
    end subroutine run_size

    subroutine cpu_clock(t)
        real(8), intent(out) :: t
        integer(8) :: c, r
        call system_clock(count=c, count_rate=r)
        t = real(c, 8) / real(r, 8)
    end subroutine cpu_clock

    function median(x) result(m)
        real(8), intent(in) :: x(:)
        real(8) :: m
        real(8), allocatable :: y(:)
        integer :: i, j, n
        real(8) :: tmp
        n = size(x); allocate(y(n)); y = x
        do i = 1, n - 1
            do j = i + 1, n
                if (y(j) < y(i)) then; tmp = y(i); y(i) = y(j); y(j) = tmp; end if
            end do
        end do
        if (mod(n, 2) == 1) then; m = y((n + 1) / 2)
        else; m = 0.5_8 * (y(n / 2) + y(n / 2 + 1)); end if
    end function median

    function gflops(s, t) result(g)
        integer, intent(in) :: s
        real(8), intent(in) :: t
        real(8) :: g
        if (t > 0.0_8) then; g = real(s, 8)**3 / t / 1.0e9_8
        else; g = 0.0_8; end if
    end function gflops

    subroutine emit_console(side, uplo, trans, diag, s, t_subject, t_mig)
        character, intent(in) :: side, uplo, trans, diag
        integer, intent(in) :: s
        real(8), intent(in) :: t_subject, t_mig
        real(8) :: g_ov, g_mig, speedup
        g_ov = gflops(s, t_subject); g_mig = gflops(s, t_mig)
        if (t_subject > 0.0_8) then; speedup = t_mig / t_subject
        else; speedup = 0.0_8; end if
        print '(a1,4x,a1,4x,a1,4x,a1,5x,i6,4x,f12.4,7x,f12.4,4x,f7.2,a)', &
            side, uplo, trans, diag, s, g_ov, g_mig, speedup, 'x'
    end subroutine emit_console

    subroutine emit_json(io, side, uplo, trans, diag, s, t_subject, t_mig, last)
        integer, intent(in) :: io, s
        character, intent(in) :: side, uplo, trans, diag
        real(8), intent(in) :: t_subject, t_mig
        logical, intent(in) :: last
        write(io, '(a)') '    {'
        write(io, '(3a)') '      "side": "', side, '",'
        write(io, '(3a)') '      "uplo": "', uplo, '",'
        write(io, '(3a)') '      "trans": "', trans, '",'
        write(io, '(3a)') '      "diag": "', diag, '",'
        write(io, '(a,i0,a)') '      "size": ', s, ','
        write(io, '(a,es16.8,a)') '      "t_overlay_s": ',  t_subject,  ','
        write(io, '(a,es16.8,a)') '      "t_migrated_s": ', t_mig, ','
        write(io, '(a,es16.8,a)') '      "gflops_subject": ',  gflops(s, t_subject),  ','
        write(io, '(a,es16.8)')   '      "gflops_migrated": ', gflops(s, t_mig)
        if (last) then; write(io, '(a)') '    }'
        else; write(io, '(a)') '    },'; end if
    end subroutine emit_json

end program bench_wtrsm
