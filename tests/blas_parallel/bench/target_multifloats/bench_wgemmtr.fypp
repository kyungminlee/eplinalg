! bench_wgemmtr — multifloats GEMMTR.
program bench_wgemmtr
    use multifloats
    use fuzz_util, only: fill_matrix_complex
    implicit none
    interface
        subroutine wgemmtr(uplo, transa, transb, n, k, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: real64x2, cmplx64x2
            character, intent(in) :: uplo, transa, transb
            integer, intent(in) :: n, k, lda, ldb, ldc
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), b(ldb, *)
            type(cmplx64x2), intent(inout) :: c(ldc, *)
        end subroutine
        subroutine wgemmtr_migrated(uplo, transa, transb, n, k, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: real64x2, cmplx64x2
            character, intent(in) :: uplo, transa, transb
            integer, intent(in) :: n, k, lda, ldb, ldc
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), b(ldb, *)
            type(cmplx64x2), intent(inout) :: c(ldc, *)
        end subroutine
    end interface
    integer :: iters, nsizes, i
    integer, allocatable :: sizes(:)
    type(cmplx64x2), allocatable :: A(:), B(:), C(:)
    type(cmplx64x2) :: alpha, beta
    real(8) :: t_subject, t_mig
    iters = read_int_env('BLAS_BENCH_ITERS', 2)
    call read_sizes(sizes); nsizes = size(sizes)
    alpha = cmplx64x2(real64x2(0.7_8), real64x2(0.1_8)); beta = cmplx64x2(real64x2(0.3_8), real64x2(0.2_8))
    print '(a)', 'ulo  size      subject GF/s   migrated GF/s   speedup'
    block
        character, parameter :: ULS(2) = ['U', 'L']
        integer :: itr, idx
        real(8) :: tov, tmig
        do itr = 1, 2
            do idx = 1, nsizes
                call run(ULS(itr), sizes(idx), iters, tov, tmig)
                call emit(ULS(itr), sizes(idx), tov, tmig)
            end do
        end do
    end block
contains
    function read_int_env(name, dflt) result(v)
        character(len=*), intent(in) :: name; integer, intent(in) :: dflt; integer :: v, ios; character(len=64) :: buf
        v = dflt; call get_environment_variable(name, buf, status=ios)
        if (ios == 0 .and. len_trim(buf) > 0) then; read(buf, *, iostat=ios) v; if (ios /= 0) v = dflt; end if
    end function
    subroutine read_sizes(arr)
        integer, allocatable, intent(out) :: arr(:)
        character(len=256) :: buf
        integer :: ios, i, j, n, val
        character(len=32) :: tok
        call get_environment_variable('BLAS_BENCH_SIZES', buf, status=ios)
        if (ios /= 0 .or. len_trim(buf) == 0) then; arr = [128, 256, 512]; return; end if
        n = 1
        do i = 1, len_trim(buf); if (buf(i:i) == ',') n = n + 1; end do
        allocate(arr(n)); j = 1; tok = ''; n = 0
        do i = 1, len_trim(buf) + 1
            if (i > len_trim(buf) .or. buf(i:i) == ',') then
                read(tok, *, iostat=ios) val; if (ios == 0) then; n = n + 1; arr(n) = val; end if; tok = ''; j = 1
            else; tok(j:j) = buf(i:i); j = j + 1; end if
        end do
        if (n < size(arr)) arr = arr(1:n)
    end subroutine
    subroutine run(ul, s, iters, t_subject, t_mig)
        character, intent(in) :: ul; integer, intent(in) :: s, iters; real(8), intent(out) :: t_subject, t_mig
        integer :: it; real(8), allocatable :: so(:), sm(:); real(8) :: t0, t1
        allocate(A(s*s), B(s*s), C(s*s), so(iters), sm(iters))
        call fill_matrix_complex(A, s, s, s); call fill_matrix_complex(B, s, s, s); call fill_matrix_complex(C, s, s, s)
        call wgemmtr(ul, 'N', 'N', s, s, alpha, A, s, B, s, beta, C, s)
        call wgemmtr_migrated(ul, 'N', 'N', s, s, alpha, A, s, B, s, beta, C, s)
        do it = 1, iters
            call clk(t0); call wgemmtr(ul, 'N', 'N', s, s, alpha, A, s, B, s, beta, C, s); call clk(t1); so(it) = t1 - t0
            call clk(t0); call wgemmtr_migrated(ul, 'N', 'N', s, s, alpha, A, s, B, s, beta, C, s); call clk(t1); sm(it) = t1 - t0
        end do
        t_subject = med(so); t_mig = med(sm); deallocate(A, B, C, so, sm)
    end subroutine
    subroutine clk(t)
        real(8), intent(out) :: t; integer(8) :: c, r
        call system_clock(count=c, count_rate=r); t = real(c, 8) / real(r, 8)
    end subroutine
    function med(x) result(m)
        real(8), intent(in) :: x(:); real(8) :: m; real(8), allocatable :: y(:); integer :: i, j, n; real(8) :: tmp
        n = size(x); allocate(y(n)); y = x
        do i = 1, n - 1; do j = i + 1, n; if (y(j) < y(i)) then; tmp = y(i); y(i) = y(j); y(j) = tmp; end if; end do; end do
        if (mod(n, 2) == 1) then; m = y((n + 1) / 2); else; m = 0.5_8 * (y(n / 2) + y(n / 2 + 1)); end if
    end function
    subroutine emit(ul, s, to, tm)
        character, intent(in) :: ul; integer, intent(in) :: s; real(8), intent(in) :: to, tm
        real(8) :: go, gm, sp
        go = 4.0_8 * real(s, 8)**3 / to / 1.0e9_8
        gm = 4.0_8 * real(s, 8)**3 / tm / 1.0e9_8
        if (to > 0.0_8) then; sp = tm / to; else; sp = 0.0_8; end if
        print '(a1,3x,i6,4x,f12.4,4x,f12.4,4x,f7.2,a)', ul, s, go, gm, sp, 'x'
    end subroutine
end program
