! bench_mspr2 — multifloats real DD symm/Herm packed rank-2.

program bench_mspr2
    use multifloats
    use fuzz_util, only: fill_matrix_real
    implicit none
    interface
        subroutine mspr2(uplo, n, alpha, x, incx, y, incy, ap)
            import :: real64x2, real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, incx, incy
            type(real64x2), intent(in) :: alpha
            type(real64x2), intent(in) :: x(*), y(*)
            type(real64x2), intent(inout) :: ap(*)
        end subroutine mspr2
        subroutine mspr2_migrated(uplo, n, alpha, x, incx, y, incy, ap)
            import :: real64x2, real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, incx, incy
            type(real64x2), intent(in) :: alpha
            type(real64x2), intent(in) :: x(*), y(*)
            type(real64x2), intent(inout) :: ap(*)
        end subroutine mspr2_migrated
    end interface
    integer :: iters, warmup, nsizes, i, iup
    integer, allocatable :: sizes(:)
    type(real64x2), allocatable :: AP(:), AP_init(:), X(:), Y(:)
    type(real64x2) :: alpha
    real(8) :: t_subject, t_mig
    character(len=1), parameter :: UPLOS(2) = ['L', 'U']
    iters = read_int_env('BLAS_BENCH_ITERS', 4); warmup = read_int_env('BLAS_BENCH_WARMUP', 1)
    call read_sizes(sizes); nsizes = size(sizes)
    alpha = real64x2(0.7_8)
    print '(a)', 'uplo    size      subject GF/s   migrated GF/s   speedup'
    do iup = 1, 2; do i = 1, nsizes
        call run_size(UPLOS(iup), sizes(i), iters, warmup, t_subject, t_mig)
        call emit(UPLOS(iup), sizes(i), t_subject, t_mig)
    end do; end do
contains
    function read_int_env(name, dflt) result(v)
        character(len=*), intent(in) :: name; integer, intent(in) :: dflt; integer :: v, ios
        character(len=64) :: buf
        v = dflt; call get_environment_variable(name, buf, status=ios)
        if (ios == 0 .and. len_trim(buf) > 0) then; read(buf, *, iostat=ios) v; if (ios /= 0) v = dflt; end if
    end function
    subroutine read_sizes(arr)
        integer, allocatable, intent(out) :: arr(:); character(len=256) :: buf
        integer :: ios, i, j, n, val; character(len=32) :: tok
        call get_environment_variable('BLAS_BENCH_SIZES', buf, status=ios)
        if (ios /= 0 .or. len_trim(buf) == 0) then; arr = [128, 256, 512, 1024]; return; end if
        n = 1; do i = 1, len_trim(buf); if (buf(i:i) == ',') n = n + 1; end do
        allocate(arr(n)); j = 1; tok = ''; n = 0
        do i = 1, len_trim(buf) + 1
            if (i > len_trim(buf) .or. buf(i:i) == ',') then
                read(tok, *, iostat=ios) val
                if (ios == 0) then; n = n + 1; arr(n) = val; end if
                tok = ''; j = 1
            else; tok(j:j) = buf(i:i); j = j + 1; end if
        end do
        if (n < size(arr)) arr = arr(1:n)
    end subroutine
    subroutine clk(t)
        real(8), intent(out) :: t; integer(8) :: c, r
        call system_clock(count=c, count_rate=r); t = real(c, 8) / real(r, 8)
    end subroutine
    function med(x) result(m)
        real(8), intent(in) :: x(:); real(8) :: m; real(8), allocatable :: y(:)
        integer :: i, j, n; real(8) :: tmp
        n = size(x); allocate(y(n)); y = x
        do i = 1, n - 1; do j = i + 1, n; if (y(j) < y(i)) then; tmp = y(i); y(i) = y(j); y(j) = tmp; end if; end do; end do
        if (mod(n, 2) == 1) then; m = y((n + 1) / 2); else; m = 0.5_8 * (y(n / 2) + y(n / 2 + 1)); end if
    end function
    subroutine run_size(uplo, s, iters, warmup, t_subject, t_mig)
        character, intent(in) :: uplo; integer, intent(in) :: s, iters, warmup
        real(8), intent(out) :: t_subject, t_mig
        integer :: it, plen
        real(8), allocatable :: so(:), sm(:); real(8) :: t0, t1
        plen = s * (s + 1) / 2
        allocate(AP(plen), AP_init(plen), X(s), Y(s)); allocate(so(iters), sm(iters))
        call fill_matrix_real(AP_init, plen, 1, plen); call fill_matrix_real(X, s, 1, s); call fill_matrix_real(Y, s, 1, s)
        do it = 1, warmup
            AP = AP_init; call mspr2(uplo, s, alpha, X, 1, Y, 1, AP)
            AP = AP_init; call mspr2_migrated(uplo, s, alpha, X, 1, Y, 1, AP)
        end do
        do it = 1, iters
            AP = AP_init; call clk(t0)
            call mspr2(uplo, s, alpha, X, 1, Y, 1, AP)
            call clk(t1); so(it) = t1 - t0
            AP = AP_init; call clk(t0)
            call mspr2_migrated(uplo, s, alpha, X, 1, Y, 1, AP)
            call clk(t1); sm(it) = t1 - t0
        end do
        t_subject = med(so); t_mig = med(sm)
        deallocate(AP, AP_init, X, Y, so, sm)
    end subroutine
    subroutine emit(uplo, s, to, tm)
        character, intent(in) :: uplo; integer, intent(in) :: s; real(8), intent(in) :: to, tm
        real(8) :: go, gm, sp, flops
        flops = 4.0_8 * real(s, 8) ** 2
        if (to > 0.0_8) then; go = flops / to / 1.0e9_8; else; go = 0.0_8; end if
        if (tm > 0.0_8) then; gm = flops / tm / 1.0e9_8; else; gm = 0.0_8; end if
        if (to > 0.0_8) then; sp = tm / to; else; sp = 0.0_8; end if
        print '(a1,5x,i6,4x,f12.4,4x,f12.4,4x,f7.2,a)', uplo, s, go, gm, sp, 'x'
    end subroutine
end program
