#! Consistency fuzz — real DOT function: returns sum(x*y).
program fuzz_${routine}$
    use fuzz_util
    implicit none
    interface
        function ${routine}$(n, x, incx, y, incy) result(d)
            import :: rk
            integer, intent(in) :: n, incx, incy
            real(rk), intent(in) :: x(*), y(*)
            real(rk) :: d
        end function
        function ${routine}$_migrated(n, x, incx, y, incy) result(d)
            import :: rk
            integer, intent(in) :: n, incx, incy
            real(rk), intent(in) :: x(*), y(*)
            real(rk) :: d
        end function
    end interface
    integer :: seed, ncases, ic, n, incx, incy, lenx, leny, fails
    real(rk) :: d_ov, d_mig, err, tol
    real(rk), allocatable :: X(:), Y(:)
    seed = read_seed(); ncases = read_cases(); call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 4096); incx = rand_incx(); incy = rand_incx()
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        lenx = 1 + (n - 1) * abs(incx); leny = 1 + (n - 1) * abs(incy)
        allocate(X(lenx), Y(leny))
        call fill_matrix_real(X, lenx, 1, lenx); call fill_matrix_real(Y, leny, 1, leny)
        d_ov  = ${routine}$(n, X, incx, Y, incy)
        d_mig = ${routine}$_migrated(n, X, incx, Y, incy)
        if (abs(d_mig) < tiny(1.0_rk)) then; err = abs(d_ov - d_mig)
        else; err = abs(d_ov - d_mig) / abs(d_mig); end if
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,3i6,a,es12.4)', 'FAIL ', ic, ' n,incx,incy=', n, incx, incy, ' err=', err
        end if
        deallocate(X, Y)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
