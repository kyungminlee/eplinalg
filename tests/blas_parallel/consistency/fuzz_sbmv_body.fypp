#! Consistency fuzz driver — real SBMV.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, k, lda, incx, incy
            real(rk), intent(in)    :: alpha, beta
            real(rk), intent(in)    :: a(lda, *), x(*)
            real(rk), intent(inout) :: y(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, k, lda, incx, incy
            real(rk), intent(in)    :: alpha, beta
            real(rk), intent(in)    :: a(lda, *), x(*)
            real(rk), intent(inout) :: y(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, n, k, lda, fails
    character :: uplo
    real(rk) :: alpha, beta, err, tol
    real(rk), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u

    seed = read_seed(); ncases = read_cases()
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        k = rand_int_log(0, min(n - 1, 8)); if (k < 0) k = 0
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta(alpha, beta)
        lda = (k + 1) + rand_pad()
        allocate(A(lda * n), X(n), Y0(n), Y_ov(n), Y_mig(n))
        call fill_matrix_real(A, k + 1, n, lda)
        call fill_matrix_real(X, n, 1, n)
        call fill_matrix_real(Y0, n, 1, n)
        Y_ov = Y0; Y_mig = Y0
        call ${routine}$(uplo, n, k, alpha, A, lda, X, 1, beta, Y_ov, 1)
        call ${routine}$_migrated(uplo, n, k, alpha, A, lda, X, 1, beta, Y_mig, 1)
        block
            integer :: i
            real(rk) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, n
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = tiny(1.0_rk)
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i4,a,es12.4)', 'FAIL ', ic, ' U=', uplo, ' n=', n, ' k=', k, ' err=', err
        end if
        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    if (fails > 0) error stop 1
end program fuzz_${routine}$
