#! Consistency fuzz driver — real SYR.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, n, alpha, x, incx, a, lda)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda, incx
            real(rk), intent(in)    :: alpha
            real(rk), intent(in)    :: x(*)
            real(rk), intent(inout) :: a(lda, *)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, n, alpha, x, incx, a, lda)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda, incx
            real(rk), intent(in)    :: alpha
            real(rk), intent(in)    :: x(*)
            real(rk), intent(inout) :: a(lda, *)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, n, lda, fails, incx, lenx
    character :: uplo
    real(rk) :: alpha, dummy_beta, err, tol
    real(rk), allocatable :: A0(:), A_ov(:), A_mig(:), X(:)
    real(8) :: u

    seed = read_seed(); ncases = read_cases()

    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta(alpha, dummy_beta)
        lda = n + rand_pad(); if (lda < 1) lda = 1
        incx = rand_incx()
        lenx = 1 + (n - 1) * abs(incx)
        allocate(A0(lda * n), A_ov(lda * n), A_mig(lda * n), X(lenx))
        call fill_matrix_real(A0, n, n, lda)
        call fill_matrix_real(X, lenx, 1, lenx)
        A_ov = A0; A_mig = A0
        call ${routine}$(uplo, n, alpha, X, incx, A_ov, lda)
        call ${routine}$_migrated(uplo, n, alpha, X, incx, A_mig, lda)
        block
            integer :: i, j, idx
            real(rk) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * lda + i
                    if ((uplo == 'L' .and. i >= j) .or. (uplo == 'U' .and. i <= j)) then
                        a_abs = abs(A_mig(idx)); if (a_abs > ref_max) ref_max = a_abs
                        d_abs = abs(A_ov(idx) - A_mig(idx)); if (d_abs > diff_max) diff_max = d_abs
                    end if
                end do
            end do
            tiny_val = tiny(1.0_rk)
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i3)', 'FAIL ', ic, ' U=', uplo, ' n=', n, ' incx=', incx
        end if
        deallocate(A0, A_ov, A_mig, X)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
