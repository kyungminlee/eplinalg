#! Consistency fuzz driver — complex TRSV, TRANS ∈ {N,T,C}.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, trans, diag, n, a, lda, x, incx)
            import :: rk
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, lda, incx
            complex(rk), intent(in)    :: a(lda, *)
            complex(rk), intent(inout) :: x(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, trans, diag, n, a, lda, x, incx)
            import :: rk
            character, intent(in) :: uplo, trans, diag
            integer,   intent(in) :: n, lda, incx
            complex(rk), intent(in)    :: a(lda, *)
            complex(rk), intent(inout) :: x(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic, i
    integer :: n, lda, incx, lenx
    integer :: fails
    character :: uplo, trans, diag
    complex(rk) :: aii
    real(rk) :: err, tol
    complex(rk), allocatable :: A(:), X0(:), X_ov(:), X_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 96)
        tol = max(10.0_rk, 8.0_rk * real(n, rk)) * eps
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call random_number(u)
        if (u < 1.0_8/3.0_8) then; trans = 'N'
        else if (u < 2.0_8/3.0_8) then; trans = 'T'
        else; trans = 'C'
        end if
        call random_number(u)
        if (u < 0.5_8) then; diag = 'N'; else; diag = 'U'; end if
        lda = n + rand_pad()
        if (lda < 1) lda = 1
        incx = rand_incx()
        lenx = 1 + (n - 1) * abs(incx)

        allocate(A(lda * n), X0(lenx), X_ov(lenx), X_mig(lenx))

        call fill_matrix_complex(A,  n, n, lda)
        do i = 1, n
            aii = A((i - 1) * lda + i)
            A((i - 1) * lda + i) = aii + cmplx(real(n + 1, rk), 0.0_rk, rk)
        end do
        call fill_matrix_complex(X0, lenx, 1, lenx)
        X_ov  = X0
        X_mig = X0

        call ${routine}$(uplo, trans, diag, n, A, lda, X_ov,  incx)
        call ${routine}$_migrated(uplo, trans, diag, n, A, lda, X_mig, incx)

        block
            integer :: i
            real(rk) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            complex(rk) :: dz
            ref_max = 0.0_rk; diff_max = 0.0_rk
            ! Non-strided positions retain X0 in both arrays so they
            ! compare equal; only the strided positions are modified.
            do i = 1, lenx
                a_abs = abs(X_mig(i))
                if (a_abs > ref_max) ref_max = a_abs
                dz = X_ov(i) - X_mig(i)
                d_abs = abs(dz)
                if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = tiny(1.0_rk)
            if (ref_max < tiny_val) then; err = diff_max
            else;                          err = diff_max / ref_max
            end if
        end block

        call err_stats_record(err)

        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,3a1,a,i6,a,i6,a,i3,a,es12.4,a,es12.4)', &
                'FAIL case ', ic, '  UTD=', uplo, trans, diag, &
                '  n=', n, '  lda=', lda, '  incx=', incx, &
                '  err=', err, '  tol=', tol
        end if

        deallocate(A, X0, X_ov, X_mig)
    end do

    print '(a,i0,a,i0,a,i0)', &
        'fuzz_${routine}$: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
