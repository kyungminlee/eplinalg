#! Consistency fuzz driver — Hermitian HEMV.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, n, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda, incx, incy
            complex(rk), intent(in)    :: alpha, beta
            complex(rk), intent(in)    :: a(lda, *), x(*)
            complex(rk), intent(inout) :: y(*)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, n, alpha, a, lda, x, incx, beta, y, incy)
            import :: rk
            character, intent(in) :: uplo
            integer,   intent(in) :: n, lda, incx, incy
            complex(rk), intent(in)    :: alpha, beta
            complex(rk), intent(in)    :: a(lda, *), x(*)
            complex(rk), intent(inout) :: y(*)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: n, lda, incx, incy, lenx, leny
    integer :: fails
    character :: uplo
    complex(rk) :: alpha, beta
    real(rk) :: err, tol
    complex(rk), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        tol = max(10.0_rk, 4.0_rk * real(n, rk)) * eps
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta_complex(alpha, beta)
        lda = n + rand_pad()
        if (lda < 1) lda = 1
        incx = rand_incx(); incy = rand_incx()
        lenx = 1 + (n - 1) * abs(incx)
        leny = 1 + (n - 1) * abs(incy)

        allocate(A(lda * n), X(lenx), Y0(leny), Y_ov(leny), Y_mig(leny))

        call fill_matrix_complex(A,  n,    n, lda)
        call fill_matrix_complex(X,  lenx, 1, lenx)
        call fill_matrix_complex(Y0, leny, 1, leny)
        ! Hermitian input: force diagonal real.
        block
            integer :: i, idx
            do i = 1, n
                idx = (i - 1) * lda + i
                A(idx) = cmplx(real(A(idx), rk), 0.0_rk, rk)
            end do
        end block
        Y_ov  = Y0
        Y_mig = Y0

        call ${routine}$(uplo, n, alpha, A, lda, X, incx, beta, Y_ov,  incy)
        call ${routine}$_migrated(uplo, n, alpha, A, lda, X, incx, beta, Y_mig, incy)

        block
            integer :: i
            real(rk) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            complex(rk) :: dz
            ref_max = 0.0_rk; diff_max = 0.0_rk
            do i = 1, leny
                a_abs = abs(Y_mig(i))
                if (a_abs > ref_max) ref_max = a_abs
                dz = Y_ov(i) - Y_mig(i)
                d_abs = abs(dz)
                if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = tiny(1.0_rk)
            if (ref_max < tiny_val) then; err = diff_max
            else;                          err = diff_max / ref_max
            end if
        end block

        call err_stats_record(err)

        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i6,a,i3,a,i3,a,es12.4,a,es12.4)', &
                'FAIL case ', ic, '  U=', uplo, '  n=', n, &
                '  lda=', lda, '  incx=', incx, '  incy=', incy, &
                '  err=', err, '  tol=', tol
        end if

        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do

    print '(a,i0,a,i0,a,i0)', &
        'fuzz_${routine}$: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program fuzz_${routine}$
