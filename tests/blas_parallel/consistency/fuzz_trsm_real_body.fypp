#! Consistency fuzz driver — real TRSM, parameterized by routine name.
#!
#! Per-target shim sets:
#!   routine    e.g. 'etrsm' (kind10), 'qtrsm' (kind16), 'mtrsm' (mf)
#!
#! For each random case: generate a well-conditioned triangular A
#! (diagonal in [1, 2], off-diagonal in [-1, 1]/M so the condition
#! number stays bounded), random B, random alpha. Call both
#! <routine>_ (overlay) and <routine>_migrated_ on identical inputs.
#! Compare X (the overwritten B) at REAL(KIND=rk) tolerance.
#!
#! Tolerance: TRSM has condition-number-dependent error. With our
#! controlled-condition A, ||X_ov - X_mig|| / ||X|| ≤ O(M·eps·κ(A)).
#! With κ bounded by O(M), tol = max(20, 8·M²)·eps is safe.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(side, uplo, transa, diag, m, n, alpha, &
                               a, lda, b, ldb)
            import :: rk
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            real(rk),  intent(in) :: alpha
            real(rk),  intent(in) :: a(lda, *)
            real(rk),  intent(inout) :: b(ldb, *)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(side, uplo, transa, diag, m, n, alpha, &
                                        a, lda, b, ldb)
            import :: rk
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            real(rk),  intent(in) :: alpha
            real(rk),  intent(in) :: a(lda, *)
            real(rk),  intent(inout) :: b(ldb, *)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: m, n, lda, ldb, na
    integer :: fails, sentinel_fails, bad_ov, bad_mig
    character :: side, uplo, transa, diag
    real(rk) :: alpha, err, tol, scale
    real(rk), allocatable :: A(:), B0(:), B_ov(:), B_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    sentinel_fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 128)
        n = rand_int_log(1, 128)
        call random_number(u)
        if (u < 0.5_8) then; side = 'L'; else; side = 'R'; end if
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        transa = rand_trans()
        call random_number(u)
        if (u < 0.3_8) then; diag = 'U'; else; diag = 'N'; end if
        ! alpha in [-1, 1] (avoid 0 because that's the quick-return path
        ! and produces all zeros — not interesting for residual checks)
        call random_number(u)
        alpha = real(2.0_8 * u - 1.0_8, rk)

        na = m
        if (side == 'R') na = n
        lda = na + rand_pad()
        ldb = m  + rand_pad()
        if (lda < 1) lda = 1
        if (ldb < 1) ldb = 1

        allocate(A(lda * na))
        allocate(B0(ldb * n))
        allocate(B_ov(ldb * n))
        allocate(B_mig(ldb * n))

        ! Fill A as a well-conditioned triangular matrix:
        !   - Off-diagonal entries small: [-1, 1] / max(M, 1) (kept ≤ 1)
        !   - Diagonal entries in [1, 2] (bounded away from 0)
        ! Other-triangle entries are sentinel-filled (must not be read).
        call fill_matrix_real(A, na, na, lda)
        scale = 1.0_rk / real(max(na, 1), rk)
        block
            integer :: i, j, idx
            real(8) :: r
            do j = 1, na
                do i = 1, na
                    idx = (j - 1) * lda + i
                    if (uplo == 'L') then
                        if (i > j) then
                            A(idx) = A(idx) * scale
                        else if (i == j) then
                            call random_number(r)
                            A(idx) = real(1.0_8 + r, rk)
                        else
                            A(idx) = sentinel_re
                        end if
                    else  ! uplo == 'U'
                        if (i < j) then
                            A(idx) = A(idx) * scale
                        else if (i == j) then
                            call random_number(r)
                            A(idx) = real(1.0_8 + r, rk)
                        else
                            A(idx) = sentinel_re
                        end if
                    end if
                end do
            end do
        end block
        call fill_matrix_real(B0, m, n, ldb)
        B_ov  = B0
        B_mig = B0

        call ${routine}$(side, uplo, transa, diag, m, n, alpha, &
                         A, lda, B_ov, ldb)
        call ${routine}$_migrated(side, uplo, transa, diag, m, n, alpha, &
                                  A, lda, B_mig, ldb)
        err = max_rel_err_real(B_ov, B_mig, m, n, ldb)
        bad_ov  = check_sentinels_real(B_ov,  m, n, ldb)
        bad_mig = check_sentinels_real(B_mig, m, n, ldb)

        ! TRSM tolerance — quadratic in dimension for the rank-1 form
        ! over a well-conditioned system. 8·M²·eps gives generous margin.
        tol = max(20.0_rk, 8.0_rk * real(na, rk)**2) * eps

        call err_stats_record(err)

        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,4a1,a,2i6,a,2i6,a,es12.4,a,es12.4)', &
                'FAIL case ', ic, '  SUTD=', side, uplo, transa, diag, &
                '  mn=', m, n, '  lda/ldb=', lda, ldb, &
                '  err=', err, '  tol=', tol
        end if
        if (bad_ov /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL overlay  case ', ic
        end if
        if (bad_mig /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL migrated case ', ic
        end if

        deallocate(A, B0, B_ov, B_mig)
    end do

    print '(a,i0,a,i0,a,i0,a,i0)', &
        'fuzz_${routine}$: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails, ' sentinel_fails=', sentinel_fails

    call err_stats_print()
    if (fails > 0 .or. sentinel_fails > 0) error stop 1
end program fuzz_${routine}$
