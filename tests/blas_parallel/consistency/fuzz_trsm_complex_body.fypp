#! Consistency fuzz driver — complex TRSM, parameterized by routine name.
#! Same structure as the real body, but uses complex(rk) types and
#! treats 'C' as a distinct transpose option.

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(side, uplo, transa, diag, m, n, alpha, &
                               a, lda, b, ldb)
            import :: rk
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            complex(rk), intent(in) :: alpha
            complex(rk), intent(in) :: a(lda, *)
            complex(rk), intent(inout) :: b(ldb, *)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(side, uplo, transa, diag, m, n, alpha, &
                                        a, lda, b, ldb)
            import :: rk
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            complex(rk), intent(in) :: alpha
            complex(rk), intent(in) :: a(lda, *)
            complex(rk), intent(inout) :: b(ldb, *)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: m, n, lda, ldb, na
    integer :: fails, sentinel_fails, bad_ov, bad_mig
    character :: side, uplo, transa, diag
    complex(rk) :: alpha
    real(rk) :: err, tol, scale_a
    complex(rk), allocatable :: A(:), B0(:), B_ov(:), B_mig(:)
    real(8) :: u, ur, ui

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    sentinel_fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 96)
        n = rand_int_log(1, 96)
        call random_number(u)
        if (u < 0.5_8) then; side = 'L'; else; side = 'R'; end if
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        transa = rand_trans_complex()
        call random_number(u)
        if (u < 0.3_8) then; diag = 'U'; else; diag = 'N'; end if
        call random_number(ur); call random_number(ui)
        alpha = cmplx(real(2.0_8*ur - 1.0_8, rk), &
                      real(2.0_8*ui - 1.0_8, rk), rk)

        na = m
        if (side == 'R') na = n
        lda = na + rand_pad()
        ldb = m  + rand_pad()
        if (lda < 1) lda = 1
        if (ldb < 1) ldb = 1

        allocate(A(lda * na))
        allocate(B0(ldb * n))
        allocate(B_ov(ldb * n))
        allocate(B_mig(ldb * n))

        call fill_matrix_complex(A, na, na, lda)
        scale_a = 1.0_rk / real(max(na, 1), rk)
        block
            integer :: i, j, idx
            real(8) :: r1, r2
            do j = 1, na
                do i = 1, na
                    idx = (j - 1) * lda + i
                    if (uplo == 'L') then
                        if (i > j) then
                            A(idx) = A(idx) * scale_a
                        else if (i == j) then
                            call random_number(r1); call random_number(r2)
                            A(idx) = cmplx(real(1.0_8 + r1, rk), &
                                           real(0.5_8 * r2, rk), rk)
                        else
                            A(idx) = cmplx(sentinel_re, sentinel_im, rk)
                        end if
                    else
                        if (i < j) then
                            A(idx) = A(idx) * scale_a
                        else if (i == j) then
                            call random_number(r1); call random_number(r2)
                            A(idx) = cmplx(real(1.0_8 + r1, rk), &
                                           real(0.5_8 * r2, rk), rk)
                        else
                            A(idx) = cmplx(sentinel_re, sentinel_im, rk)
                        end if
                    end if
                end do
            end do
        end block
        call fill_matrix_complex(B0, m, n, ldb)
        B_ov  = B0
        B_mig = B0

        call ${routine}$(side, uplo, transa, diag, m, n, alpha, &
                         A, lda, B_ov, ldb)
        call ${routine}$_migrated(side, uplo, transa, diag, m, n, alpha, &
                                  A, lda, B_mig, ldb)
        err = max_rel_err_complex(B_ov, B_mig, m, n, ldb)
        bad_ov  = check_sentinels_complex(B_ov,  m, n, ldb)
        bad_mig = check_sentinels_complex(B_mig, m, n, ldb)

        tol = max(20.0_rk, 8.0_rk * real(na, rk)**2) * eps

        call err_stats_record(err)

        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,4a1,a,2i6,a,2i6,a,es12.4,a,es12.4)', &
                'FAIL case ', ic, '  SUTD=', side, uplo, transa, diag, &
                '  mn=', m, n, '  lda/ldb=', lda, ldb, &
                '  err=', err, '  tol=', tol
        end if
        if (bad_ov /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL overlay  case ', ic
        end if
        if (bad_mig /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL migrated case ', ic
        end if

        deallocate(A, B0, B_ov, B_mig)
    end do

    print '(a,i0,a,i0,a,i0,a,i0)', &
        'fuzz_${routine}$: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails, ' sentinel_fails=', sentinel_fails

    call err_stats_print()
    if (fails > 0 .or. sentinel_fails > 0) error stop 1
end program fuzz_${routine}$
