! fuzz_mtbmv — multifloats real DD triangular band matrix-vector.

program fuzz_mtbmv
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine mtbmv(uplo, trans, diag, n, k, a, lda, x, incx)
            import :: real64x2
            character, intent(in) :: uplo, trans, diag
            integer, intent(in) :: n, k, lda, incx
            type(real64x2), intent(in) :: a(lda, *)
            type(real64x2), intent(inout) :: x(*)
        end subroutine mtbmv
        subroutine mtbmv_migrated(uplo, trans, diag, n, k, a, lda, x, incx)
            import :: real64x2
            character, intent(in) :: uplo, trans, diag
            integer, intent(in) :: n, k, lda, incx
            type(real64x2), intent(in) :: a(lda, *)
            type(real64x2), intent(inout) :: x(*)
        end subroutine mtbmv_migrated
    end interface
    integer :: seed, ncases, ic, n, k, lda, incx, lenx_alloc, fails, i, idx
    character :: uplo, trans, diag
    type(real64x2) :: aii, err, tol
    type(real64x2), allocatable :: A(:), X0(:), X_ov(:), X_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_mtbmv: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 96)
        k = rand_int_log(0, min(n - 1, 8)); if (k < 0) k = 0
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call random_number(u); if (u < 0.5_8) then; trans = 'N'; else; trans = 'T'; end if
        call random_number(u); if (u < 0.5_8) then; diag = 'N'; else; diag = 'U'; end if
        lda = (k + 1) + rand_pad()
        incx = rand_incx()
        lenx_alloc = 1 + (n - 1) * abs(incx)
        allocate(A(lda * n), X0(lenx_alloc), X_ov(lenx_alloc), X_mig(lenx_alloc))
        call fill_matrix_real(A, k + 1, n, lda)
        ! Boost diagonal (banded storage: row k+1 for U, row 1 for L).
        do i = 1, n
            if (uplo == 'U') then
                idx = (i - 1) * lda + (k + 1)
            else
                idx = (i - 1) * lda + 1
            end if
            aii = A(idx); A(idx) = aii + real64x2(real(n + 1, 8))
        end do
        call fill_matrix_real(X0, lenx_alloc, 1, lenx_alloc); X_ov = X0; X_mig = X0
        call mtbmv(uplo, trans, diag, n, k, A, lda, X_ov, incx)
        call mtbmv_migrated(uplo, trans, diag, n, k, A, lda, X_mig, incx)
        block
            integer :: ii
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do ii = 1, lenx_alloc
                a_abs = abs(X_mig(ii)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(X_ov(ii) - X_mig(ii)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(8.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,3a1,a,i6,a,i4,a,i3)', 'FAIL ', ic, ' UTD=', uplo, trans, diag, ' n=', n, ' k=', k, ' incx=', incx
        end if
        deallocate(A, X0, X_ov, X_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_mtbmv: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
