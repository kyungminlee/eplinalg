! fuzz_wrotg — multifloats complex DD ROTG.
program fuzz_wrotg
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine wrotg(a, b, c, s)
            import :: real64x2, cmplx64x2
            type(cmplx64x2), intent(inout) :: a
            type(cmplx64x2), intent(in) :: b
            type(real64x2), intent(out) :: c
            type(cmplx64x2), intent(out) :: s
        end subroutine
        subroutine wrotg_migrated(a, b, c, s)
            import :: real64x2, cmplx64x2
            type(cmplx64x2), intent(inout) :: a
            type(cmplx64x2), intent(in) :: b
            type(real64x2), intent(out) :: c
            type(cmplx64x2), intent(out) :: s
        end subroutine
    end interface
    integer :: seed, ncases, ic, fails
    type(cmplx64x2) :: a0, b, a_o, a_m, s_o, s_m
    type(real64x2) :: c_o, c_m, err, tol
    real(8) :: ur, ui
    seed = read_seed(); ncases = read_cases(); call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_wrotg: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        call random_number(ur); call random_number(ui)
        a0 = cmplx64x2(real64x2(2.0_8*ur-1.0_8), real64x2(2.0_8*ui-1.0_8))
        call random_number(ur); call random_number(ui)
        b  = cmplx64x2(real64x2(2.0_8*ur-1.0_8), real64x2(2.0_8*ui-1.0_8))
        a_o = a0; a_m = a0
        call wrotg(a_o, b, c_o, s_o)
        call wrotg_migrated(a_m, b, c_m, s_m)
        err = real64x2(0.0_8)
        err = max(err, crel(a_o, a_m)); err = max(err, rrel(c_o, c_m)); err = max(err, crel(s_o, s_m))
        tol = real64x2(100.0_8) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then; fails = fails + 1; print '(a,i0)', 'FAIL ', ic; end if
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_wrotg: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
contains
    function rrel(x, y) result(r)
        type(real64x2), intent(in) :: x, y
        type(real64x2) :: r, d, ay
        block; type(real64x2) :: d1, d2
        d1 = abs(x - y); d2 = abs(x + y)
        if (d1 < d2) then; d = d1; else; d = d2; end if
        ay = abs(y)
        if (ay < real64x2(tiny(1.0_8))) then; r = d; else; r = d / ay; end if
        end block
    end function
    function crel(x, y) result(r)
        type(cmplx64x2), intent(in) :: x, y
        type(real64x2) :: r, d, ay
        block; type(real64x2) :: d1, d2
        d1 = abs(x - y); d2 = abs(x + y)
        if (d1 < d2) then; d = d1; else; d = d2; end if
        ay = abs(y)
        if (ay < real64x2(tiny(1.0_8))) then; r = d; else; r = d / ay; end if
        end block
    end function
end program
