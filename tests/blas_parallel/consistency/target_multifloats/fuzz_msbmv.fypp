! fuzz_msbmv — multifloats real DD symmetric band matrix-vector.

program fuzz_msbmv
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine msbmv(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, k, lda, incx, incy
            type(real64x2), intent(in) :: alpha, beta
            type(real64x2), intent(in) :: a(lda, *), x(*)
            type(real64x2), intent(inout) :: y(*)
        end subroutine msbmv
        subroutine msbmv_migrated(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, k, lda, incx, incy
            type(real64x2), intent(in) :: alpha, beta
            type(real64x2), intent(in) :: a(lda, *), x(*)
            type(real64x2), intent(inout) :: y(*)
        end subroutine msbmv_migrated
    end interface
    integer :: seed, ncases, ic, n, k, lda, fails
    character :: uplo
    type(real64x2) :: alpha, beta, err, tol
    type(real64x2), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_msbmv: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        k = rand_int_log(0, min(n - 1, 8)); if (k < 0) k = 0
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta(alpha, beta)
        lda = (k + 1) + rand_pad()
        allocate(A(lda * n), X(n), Y0(n), Y_ov(n), Y_mig(n))
        call fill_matrix_real(A, k + 1, n, lda)
        call fill_matrix_real(X, n, 1, n); call fill_matrix_real(Y0, n, 1, n)
        Y_ov = Y0; Y_mig = Y0
        call msbmv(uplo, n, k, alpha, A, lda, X, 1, beta, Y_ov, 1)
        call msbmv_migrated(uplo, n, k, alpha, A, lda, X, 1, beta, Y_mig, 1)
        block
            integer :: i
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do i = 1, n
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i4)', 'FAIL ', ic, ' U=', uplo, ' n=', n, ' k=', k
        end if
        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_msbmv: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
