! fuzz_mtrmm — multifloats real DD triangular solve consistency.
! Same algorithm shape as fuzz_etrsm but uses type(real64x2).

program fuzz_mtrmm
    use multifloats   ! type + operators
    use fuzz_util
    implicit none

    interface
        subroutine mtrmm(side, uplo, transa, diag, m, n, alpha, &
                         a, lda, b, ldb)
            import :: real64x2
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            type(real64x2), intent(in) :: alpha
            type(real64x2), intent(in) :: a(lda, *)
            type(real64x2), intent(inout) :: b(ldb, *)
        end subroutine mtrmm
        subroutine mtrmm_migrated(side, uplo, transa, diag, m, n, alpha, &
                                  a, lda, b, ldb)
            import :: real64x2
            character, intent(in) :: side, uplo, transa, diag
            integer,   intent(in) :: m, n, lda, ldb
            type(real64x2), intent(in) :: alpha
            type(real64x2), intent(in) :: a(lda, *)
            type(real64x2), intent(inout) :: b(ldb, *)
        end subroutine mtrmm_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: m, n, lda, ldb, na
    integer :: fails, sentinel_fails, bad_ov, bad_mig
    character :: side, uplo, transa, diag
    type(real64x2) :: alpha, err, tol, a_scale
    type(real64x2), allocatable :: A(:), B0(:), B_ov(:), B_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_mtrmm: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    sentinel_fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 128)
        n = rand_int_log(1, 128)
        call random_number(u)
        if (u < 0.5_8) then; side = 'L'; else; side = 'R'; end if
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        transa = rand_trans()
        call random_number(u)
        if (u < 0.3_8) then; diag = 'U'; else; diag = 'N'; end if
        call random_number(u)
        alpha = real64x2(2.0_8 * u - 1.0_8)

        na = m
        if (side == 'R') na = n
        lda = na + rand_pad()
        ldb = m  + rand_pad()
        if (lda < 1) lda = 1
        if (ldb < 1) ldb = 1

        allocate(A(lda * na))
        allocate(B0(ldb * n))
        allocate(B_ov(ldb * n))
        allocate(B_mig(ldb * n))

        call fill_matrix_real(A, na, na, lda)
        a_scale = real64x2(1.0_8 / real(max(na, 1), 8))
        block
            integer :: i, j, idx
            real(8) :: r
            do j = 1, na
                do i = 1, na
                    idx = (j - 1) * lda + i
                    if (uplo == 'L') then
                        if (i > j) then
                            A(idx) = A(idx) * a_scale
                        else if (i == j) then
                            call random_number(r)
                            A(idx) = real64x2(1.0_8 + r)
                        else
                            A(idx) = sentinel_re
                        end if
                    else
                        if (i < j) then
                            A(idx) = A(idx) * a_scale
                        else if (i == j) then
                            call random_number(r)
                            A(idx) = real64x2(1.0_8 + r)
                        else
                            A(idx) = sentinel_re
                        end if
                    end if
                end do
            end do
        end block
        call fill_matrix_real(B0, m, n, ldb)
        B_ov  = B0
        B_mig = B0

        call mtrmm(side, uplo, transa, diag, m, n, alpha, A, lda, B_ov, ldb)
        call mtrmm_migrated(side, uplo, transa, diag, m, n, alpha, &
                            A, lda, B_mig, ldb)
        err = max_rel_err_real(B_ov, B_mig, m, n, ldb)
        bad_ov  = check_sentinels_real(B_ov,  m, n, ldb)
        bad_mig = check_sentinels_real(B_mig, m, n, ldb)

        tol = max(real64x2(20.0_8), &
                  real64x2(8.0_8 * real(na, 8)**2)) * eps

        call err_stats_record(err%limbs(1))

        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,4a1,a,2i6,a,2i6)', &
                'FAIL case ', ic, '  SUTD=', side, uplo, transa, diag, &
                '  mn=', m, n, '  lda/ldb=', lda, ldb
        end if
        if (bad_ov /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL overlay  case ', ic
        end if
        if (bad_mig /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL migrated case ', ic
        end if

        deallocate(A, B0, B_ov, B_mig)
    end do

    print '(a,i0,a,i0,a,i0,a,i0)', &
        'fuzz_mtrmm: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails, ' sentinel_fails=', sentinel_fails
    call err_stats_print()
    if (fails > 0 .or. sentinel_fails > 0) error stop 1
end program fuzz_mtrmm
