! fuzz_msyr2k — multifloats real DD symmetric rank-2k consistency.

program fuzz_msyr2k
    use multifloats
    use fuzz_util
    implicit none

    interface
        subroutine msyr2k(uplo, trans, n, k, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: real64x2
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, lda, ldb, ldc
            type(real64x2), intent(in) :: alpha, beta
            type(real64x2), intent(in) :: a(lda, *), b(ldb, *)
            type(real64x2), intent(inout) :: c(ldc, *)
        end subroutine msyr2k
        subroutine msyr2k_migrated(uplo, trans, n, k, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: real64x2
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, lda, ldb, ldc
            type(real64x2), intent(in) :: alpha, beta
            type(real64x2), intent(in) :: a(lda, *), b(ldb, *)
            type(real64x2), intent(inout) :: c(ldc, *)
        end subroutine msyr2k_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: n, k, lda, ldb, ldc, rows_a, cols_a
    integer :: fails, sentinel_fails, bad_ov, bad_mig
    character :: uplo, trans
    type(real64x2) :: alpha, beta, err, tol
    type(real64x2), allocatable :: A(:), B(:), C0(:), C_ov(:), C_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_msyr2k: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    sentinel_fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 96)
        k = rand_int_log(1, 96)
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call random_number(u)
        if (u < 0.5_8) then; trans = 'N'; else; trans = 'T'; end if
        call rand_alpha_beta(alpha, beta)

        if (trans == 'N') then; rows_a = n; cols_a = k
        else;                   rows_a = k; cols_a = n
        end if
        lda = rows_a + rand_pad()
        ldb = rows_a + rand_pad()
        ldc = n      + rand_pad()
        if (lda < 1) lda = 1
        if (ldb < 1) ldb = 1
        if (ldc < 1) ldc = 1

        allocate(A(lda * cols_a))
        allocate(B(ldb * cols_a))
        allocate(C0   (ldc * n))
        allocate(C_ov (ldc * n))
        allocate(C_mig(ldc * n))

        call fill_matrix_real(A,  rows_a, cols_a, lda)
        call fill_matrix_real(B,  rows_a, cols_a, ldb)
        call fill_matrix_real(C0, n,      n,      ldc)
        block
            integer :: i, j, idx
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * ldc + i
                    if ((uplo == 'L' .and. i < j) .or. &
                        (uplo == 'U' .and. i > j)) then
                        C0(idx) = sentinel_re
                    end if
                end do
            end do
        end block
        C_ov  = C0
        C_mig = C0

        call msyr2k(uplo, trans, n, k, alpha, A, lda, B, ldb, beta, C_ov,  ldc)
        call msyr2k_migrated(uplo, trans, n, k, alpha, A, lda, B, ldb, beta, C_mig, ldc)

        block
            integer :: i, j, idx
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max  = real64x2(0.0_8)
            diff_max = real64x2(0.0_8)
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * ldc + i
                    if ((uplo == 'L' .and. i >= j) .or. &
                        (uplo == 'U' .and. i <= j)) then
                        a_abs = abs(C_mig(idx))
                        if (a_abs > ref_max) ref_max = a_abs
                        d_abs = abs(C_ov(idx) - C_mig(idx))
                        if (d_abs > diff_max) diff_max = d_abs
                    end if
                end do
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max
            else;                          err = diff_max / ref_max
            end if
        end block
        bad_ov  = check_sentinels_real(C_ov,  n, n, ldc)
        bad_mig = check_sentinels_real(C_mig, n, n, ldc)
        block
            integer :: i, j, idx
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * ldc + i
                    if ((uplo == 'L' .and. i < j) .or. &
                        (uplo == 'U' .and. i > j)) then
                        if (C_ov(idx)  /= sentinel_re) bad_ov  = j
                        if (C_mig(idx) /= sentinel_re) bad_mig = j
                    end if
                end do
            end do
        end block

        tol = max(real64x2(10.0_8), real64x2(8.0_8 * real(k, 8))) * eps

        call err_stats_record(err%limbs(1))

        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,2a1,a,2i6,a,3i6)', &
                'FAIL case ', ic, '  UT=', uplo, trans, &
                '  nk=', n, k, '  lda/ldb/ldc=', lda, ldb, ldc
        end if
        if (bad_ov /= 0) sentinel_fails = sentinel_fails + 1
        if (bad_mig /= 0) sentinel_fails = sentinel_fails + 1

        deallocate(A, B, C0, C_ov, C_mig)
    end do

    print '(a,i0,a,i0,a,i0,a,i0)', &
        'fuzz_msyr2k: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails, ' sentinel_fails=', sentinel_fails
    call err_stats_print()
    if (fails > 0 .or. sentinel_fails > 0) error stop 1
end program fuzz_msyr2k
