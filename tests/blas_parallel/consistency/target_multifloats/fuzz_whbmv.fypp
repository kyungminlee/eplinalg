! fuzz_whbmv — multifloats complex DD Hermitian band matrix-vector.

program fuzz_whbmv
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine whbmv(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: cmplx64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, k, lda, incx, incy
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), x(*)
            type(cmplx64x2), intent(inout) :: y(*)
        end subroutine whbmv
        subroutine whbmv_migrated(uplo, n, k, alpha, a, lda, x, incx, beta, y, incy)
            import :: cmplx64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, k, lda, incx, incy
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), x(*)
            type(cmplx64x2), intent(inout) :: y(*)
        end subroutine whbmv_migrated
    end interface
    integer :: seed, ncases, ic, n, k, lda, fails, i, idx
    character :: uplo
    type(cmplx64x2) :: alpha, beta
    type(real64x2)  :: err, tol
    type(cmplx64x2), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    print '(a,i0,a,i0)', 'fuzz_whbmv: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 96)
        k = rand_int_log(0, min(n - 1, 8)); if (k < 0) k = 0
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta_complex(alpha, beta)
        lda = (k + 1) + rand_pad()
        allocate(A(lda * n), X(n), Y0(n), Y_ov(n), Y_mig(n))
        call fill_matrix_complex(A, k + 1, n, lda)
        ! Force the diagonal of A real (banded storage: diagonal row).
        do i = 1, n
            if (uplo == 'U') then
                idx = (i - 1) * lda + (k + 1)
            else
                idx = (i - 1) * lda + 1
            end if
            A(idx) = cmplx64x2(A(idx)%re, real64x2(0.0_8))
        end do
        call fill_matrix_complex(X, n, 1, n); call fill_matrix_complex(Y0, n, 1, n)
        Y_ov = Y0; Y_mig = Y0
        call whbmv(uplo, n, k, alpha, A, lda, X, 1, beta, Y_ov, 1)
        call whbmv_migrated(uplo, n, k, alpha, A, lda, X, 1, beta, Y_mig, 1)
        block
            integer :: ii
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do ii = 1, n
                a_abs = abs(Y_mig(ii)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(ii) - Y_mig(ii)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(n, 8))) * eps
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i4)', 'FAIL ', ic, ' U=', uplo, ' n=', n, ' k=', k
        end if
        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_whbmv: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    if (fails > 0) error stop 1
end program
