! fuzz_whpmv — multifloats complex DD Hermitian packed matrix-vector.

program fuzz_whpmv
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine whpmv(uplo, n, alpha, ap, x, incx, beta, y, incy)
            import :: cmplx64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, incx, incy
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: ap(*), x(*)
            type(cmplx64x2), intent(inout) :: y(*)
        end subroutine whpmv
        subroutine whpmv_migrated(uplo, n, alpha, ap, x, incx, beta, y, incy)
            import :: cmplx64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, incx, incy
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: ap(*), x(*)
            type(cmplx64x2), intent(inout) :: y(*)
        end subroutine whpmv_migrated
    end interface
    integer :: seed, ncases, ic, n, plen, incx, incy, lenx_alloc, leny_alloc, fails, j, jk
    character :: uplo
    type(cmplx64x2) :: alpha, beta
    type(real64x2)  :: err, tol
    type(cmplx64x2), allocatable :: AP(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_whpmv: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 96)
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta_complex(alpha, beta)
        plen = n * (n + 1) / 2
        incx = rand_incx(); incy = rand_incx()
        lenx_alloc = 1 + (n - 1) * abs(incx)
        leny_alloc = 1 + (n - 1) * abs(incy)
        allocate(AP(plen), X(lenx_alloc), Y0(leny_alloc), Y_ov(leny_alloc), Y_mig(leny_alloc))
        call fill_matrix_complex(AP, plen, 1, plen)
        ! Force diagonal real.
        jk = 0
        do j = 1, n
            if (uplo == 'U') then
                AP(jk + j) = cmplx64x2(AP(jk + j)%re, real64x2(0.0_8))
                jk = jk + j
            else
                AP(jk + 1) = cmplx64x2(AP(jk + 1)%re, real64x2(0.0_8))
                jk = jk + (n - j + 1)
            end if
        end do
        call fill_matrix_complex(X, lenx_alloc, 1, lenx_alloc)
        call fill_matrix_complex(Y0, leny_alloc, 1, leny_alloc)
        Y_ov = Y0; Y_mig = Y0
        call whpmv(uplo, n, alpha, AP, X, incx, beta, Y_ov, incy)
        call whpmv_migrated(uplo, n, alpha, AP, X, incx, beta, Y_mig, incy)
        block
            integer :: i
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do i = 1, leny_alloc
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i3,a,i3)', 'FAIL ', ic, ' U=', uplo, ' n=', n, ' incx=', incx, ' incy=', incy
        end if
        deallocate(AP, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_whpmv: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
