! fuzz_msyr — multifloats real DD symmetric rank-1 consistency.

program fuzz_msyr
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine msyr(uplo, n, alpha, x, incx, a, lda)
            import :: real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, lda, incx
            type(real64x2), intent(in) :: alpha
            type(real64x2), intent(in) :: x(*)
            type(real64x2), intent(inout) :: a(lda, *)
        end subroutine msyr
        subroutine msyr_migrated(uplo, n, alpha, x, incx, a, lda)
            import :: real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, lda, incx
            type(real64x2), intent(in) :: alpha
            type(real64x2), intent(in) :: x(*)
            type(real64x2), intent(inout) :: a(lda, *)
        end subroutine msyr_migrated
    end interface
    integer :: seed, ncases, ic, n, lda, incx, lenx_alloc, fails
    character :: uplo
    type(real64x2) :: alpha, dummy_beta, err, tol
    type(real64x2), allocatable :: A0(:), A_ov(:), A_mig(:), X(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_msyr: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta(alpha, dummy_beta)
        lda = n + rand_pad(); if (lda < 1) lda = 1
        incx = rand_incx()
        lenx_alloc = 1 + (n - 1) * abs(incx)
        allocate(A0(lda * n), A_ov(lda * n), A_mig(lda * n), X(lenx_alloc))
        call fill_matrix_real(A0, n, n, lda)
        call fill_matrix_real(X, lenx_alloc, 1, lenx_alloc)
        A_ov = A0; A_mig = A0
        call msyr(uplo, n, alpha, X, incx, A_ov, lda)
        call msyr_migrated(uplo, n, alpha, X, incx, A_mig, lda)
        block
            integer :: i, j, idx
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do j = 1, n; do i = 1, n
                idx = (j - 1) * lda + i
                if ((uplo == 'L' .and. i >= j) .or. (uplo == 'U' .and. i <= j)) then
                    a_abs = abs(A_mig(idx)); if (a_abs > ref_max) ref_max = a_abs
                    d_abs = abs(A_ov(idx) - A_mig(idx)); if (d_abs > diff_max) diff_max = d_abs
                end if
            end do; end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6,a,i3)', 'FAIL ', ic, ' U=', uplo, ' n=', n, ' incx=', incx
        end if
        deallocate(A0, A_ov, A_mig, X)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_msyr: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
