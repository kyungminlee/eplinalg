! fuzz_mrotm — multifloats real DD ROTM.
program fuzz_mrotm
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine mrotm(n, x, incx, y, incy, param)
            import :: real64x2
            integer, intent(in) :: n, incx, incy
            type(real64x2), intent(inout) :: x(*), y(*)
            type(real64x2), intent(in) :: param(5)
        end subroutine
        subroutine mrotm_migrated(n, x, incx, y, incy, param)
            import :: real64x2
            integer, intent(in) :: n, incx, incy
            type(real64x2), intent(inout) :: x(*), y(*)
            type(real64x2), intent(in) :: param(5)
        end subroutine
    end interface
    integer :: seed, ncases, ic, n, incx, incy, lenx, leny, fails, i
    type(real64x2) :: param(5), err, tol
    type(real64x2), allocatable :: X0(:), Y0(:), X_ov(:), Y_ov(:), X_mig(:), Y_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases(); call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_mrotm: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 4096); incx = rand_incx(); incy = rand_incx()
        call random_number(u)
        if (u < 0.25_8) then
            param(1) = real64x2(-2.0_8); param(2:5) = real64x2(0.0_8)
        else if (u < 0.5_8) then
            param(1) = real64x2(-1.0_8); param(2) = real64x2(0.7_8); param(3) = real64x2(-0.2_8)
            param(4) = real64x2(0.3_8); param(5) = real64x2(0.9_8)
        else if (u < 0.75_8) then
            param(1) = real64x2(0.0_8); param(2) = real64x2(0.0_8); param(3) = real64x2(-0.4_8)
            param(4) = real64x2(0.6_8); param(5) = real64x2(0.0_8)
        else
            param(1) = real64x2(1.0_8); param(2) = real64x2(0.8_8); param(3) = real64x2(0.0_8)
            param(4) = real64x2(0.0_8); param(5) = real64x2(0.5_8)
        end if
        lenx = 1 + (n - 1) * abs(incx); leny = 1 + (n - 1) * abs(incy)
        allocate(X0(lenx), Y0(leny), X_ov(lenx), Y_ov(leny), X_mig(lenx), Y_mig(leny))
        call fill_matrix_real(X0, lenx, 1, lenx); call fill_matrix_real(Y0, leny, 1, leny)
        X_ov = X0; Y_ov = Y0; X_mig = X0; Y_mig = Y0
        call mrotm(n, X_ov, incx, Y_ov, incy, param)
        call mrotm_migrated(n, X_mig, incx, Y_mig, incy, param)
        block
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do i = 1, lenx
                a_abs = abs(X_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(X_ov(i) - X_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            do i = 1, leny
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(20.0_8), real64x2(8.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then; fails = fails + 1; print '(a,i0,a,3i6)', 'FAIL ', ic, ' n,incx,incy=', n, incx, incy; end if
        deallocate(X0, Y0, X_ov, Y_ov, X_mig, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_mrotm: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
