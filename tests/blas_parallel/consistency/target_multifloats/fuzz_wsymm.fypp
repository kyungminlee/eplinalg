! fuzz_wsymm — multifloats complex DD symmetric matrix multiply consistency.

program fuzz_wsymm
    use multifloats
    use fuzz_util
    implicit none

    interface
        subroutine wsymm(side, uplo, m, n, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: cmplx64x2
            character, intent(in) :: side, uplo
            integer,   intent(in) :: m, n, lda, ldb, ldc
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), b(ldb, *)
            type(cmplx64x2), intent(inout) :: c(ldc, *)
        end subroutine wsymm
        subroutine wsymm_migrated(side, uplo, m, n, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: cmplx64x2
            character, intent(in) :: side, uplo
            integer,   intent(in) :: m, n, lda, ldb, ldc
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), b(ldb, *)
            type(cmplx64x2), intent(inout) :: c(ldc, *)
        end subroutine wsymm_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: m, n, lda, ldb, ldc, na
    integer :: fails, sentinel_fails, bad_a_ov
    character :: side, uplo
    type(cmplx64x2) :: alpha, beta, c_sentinel
    type(real64x2)  :: err, tol
    type(cmplx64x2), allocatable :: A(:), Aref(:), B(:), C0(:), C_ov(:), C_mig(:)
    real(8) :: u

    c_sentinel = cmplx64x2(sentinel_re, sentinel_im)

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_wsymm: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    sentinel_fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 64)
        n = rand_int_log(1, 64)
        call random_number(u)
        if (u < 0.5_8) then; side = 'L'; else; side = 'R'; end if
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta_complex(alpha, beta)

        if (side == 'L') then; na = m; else; na = n; end if
        lda = na + rand_pad()
        ldb = m  + rand_pad()
        ldc = m  + rand_pad()
        if (lda < 1) lda = 1
        if (ldb < 1) ldb = 1
        if (ldc < 1) ldc = 1

        allocate(A(lda * na), Aref(lda * na))
        allocate(B(ldb * n))
        allocate(C0(ldc * n), C_ov(ldc * n), C_mig(ldc * n))

        call fill_matrix_complex(A, na, na, lda)
        block
            integer :: i, j, idx
            do j = 1, na
                do i = 1, na
                    idx = (j - 1) * lda + i
                    if ((uplo == 'L' .and. i < j) .or. &
                        (uplo == 'U' .and. i > j)) then
                        A(idx) = c_sentinel
                    end if
                end do
            end do
        end block
        Aref = A
        call fill_matrix_complex(B,  m, n, ldb)
        call fill_matrix_complex(C0, m, n, ldc)
        C_ov  = C0
        C_mig = C0

        call wsymm(side, uplo, m, n, alpha, A, lda, B, ldb, beta, C_ov,  ldc)
        bad_a_ov = 0
        block
            integer :: i
            do i = 1, lda * na
                if (A(i)%re /= Aref(i)%re .or. A(i)%im /= Aref(i)%im) then
                    bad_a_ov = i; exit
                end if
            end do
        end block
        call wsymm_migrated(side, uplo, m, n, alpha, A, lda, B, ldb, beta, C_mig, ldc)
        err = max_rel_err_complex(C_ov, C_mig, m, n, ldc)

        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(max(m, n), 8))) * eps

        call err_stats_record(err%limbs(1))

        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,2a1,a,2i6)', &
                'FAIL case ', ic, '  SU=', side, uplo, '  mn=', m, n
        end if
        if (bad_a_ov /= 0) sentinel_fails = sentinel_fails + 1

        deallocate(A, Aref, B, C0, C_ov, C_mig)
    end do

    print '(a,i0,a,i0,a,i0,a,i0)', &
        'fuzz_wsymm: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails, ' sentinel_fails=', sentinel_fails
    call err_stats_print()
    if (fails > 0 .or. sentinel_fails > 0) error stop 1
end program fuzz_wsymm
