! fuzz_mspmv — multifloats real DD symmetric packed matrix-vector.

program fuzz_mspmv
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine mspmv(uplo, n, alpha, ap, x, incx, beta, y, incy)
            import :: real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, incx, incy
            type(real64x2), intent(in) :: alpha, beta
            type(real64x2), intent(in) :: ap(*), x(*)
            type(real64x2), intent(inout) :: y(*)
        end subroutine mspmv
        subroutine mspmv_migrated(uplo, n, alpha, ap, x, incx, beta, y, incy)
            import :: real64x2
            character, intent(in) :: uplo
            integer, intent(in) :: n, incx, incy
            type(real64x2), intent(in) :: alpha, beta
            type(real64x2), intent(in) :: ap(*), x(*)
            type(real64x2), intent(inout) :: y(*)
        end subroutine mspmv_migrated
    end interface
    integer :: seed, ncases, ic, n, plen, fails
    character :: uplo
    type(real64x2) :: alpha, beta, err, tol
    type(real64x2), allocatable :: AP(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_mspmv: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        call random_number(u); if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call rand_alpha_beta(alpha, beta)
        plen = n * (n + 1) / 2
        allocate(AP(plen), X(n), Y0(n), Y_ov(n), Y_mig(n))
        call fill_matrix_real(AP, plen, 1, plen)
        call fill_matrix_real(X, n, 1, n); call fill_matrix_real(Y0, n, 1, n)
        Y_ov = Y0; Y_mig = Y0
        call mspmv(uplo, n, alpha, AP, X, 1, beta, Y_ov, 1)
        call mspmv_migrated(uplo, n, alpha, AP, X, 1, beta, Y_mig, 1)
        block
            integer :: i
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do i = 1, n
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(n, 8))) * eps
        call err_stats_record(err%limbs(1))
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,a1,a,i6)', 'FAIL ', ic, ' U=', uplo, ' n=', n
        end if
        deallocate(AP, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_mspmv: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
