! fuzz_wgemv — multifloats complex DD GEMV consistency.

program fuzz_wgemv
    use multifloats
    use fuzz_util
    implicit none
    interface
        subroutine wgemv(trans, m, n, alpha, a, lda, x, incx, beta, y, incy)
            import :: cmplx64x2
            character, intent(in) :: trans
            integer, intent(in) :: m, n, lda, incx, incy
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), x(*)
            type(cmplx64x2), intent(inout) :: y(*)
        end subroutine wgemv
        subroutine wgemv_migrated(trans, m, n, alpha, a, lda, x, incx, beta, y, incy)
            import :: cmplx64x2
            character, intent(in) :: trans
            integer, intent(in) :: m, n, lda, incx, incy
            type(cmplx64x2), intent(in) :: alpha, beta
            type(cmplx64x2), intent(in) :: a(lda, *), x(*)
            type(cmplx64x2), intent(inout) :: y(*)
        end subroutine wgemv_migrated
    end interface
    integer :: seed, ncases, ic, m, n, lda, lenx, leny, fails
    character :: trans
    type(cmplx64x2) :: alpha, beta
    type(real64x2)  :: err, tol
    type(cmplx64x2), allocatable :: A(:), X(:), Y0(:), Y_ov(:), Y_mig(:)
    real(8) :: u
    seed = read_seed(); ncases = read_cases()
    print '(a,i0,a,i0)', 'fuzz_wgemv: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        m = rand_int_log(1, 96); n = rand_int_log(1, 96)
        call random_number(u)
        if (u < 1.0_8/3.0_8) then; trans = 'N'
        else if (u < 2.0_8/3.0_8) then; trans = 'T'
        else; trans = 'C'
        end if
        call rand_alpha_beta_complex(alpha, beta)
        if (trans == 'N') then; lenx = n; leny = m; else; lenx = m; leny = n; end if
        lda = m + rand_pad(); if (lda < 1) lda = 1
        allocate(A(lda * n), X(lenx), Y0(leny), Y_ov(leny), Y_mig(leny))
        call fill_matrix_complex(A, m, n, lda)
        call fill_matrix_complex(X, lenx, 1, lenx)
        call fill_matrix_complex(Y0, leny, 1, leny)
        Y_ov = Y0; Y_mig = Y0
        call wgemv(trans, m, n, alpha, A, lda, X, 1, beta, Y_ov, 1)
        call wgemv_migrated(trans, m, n, alpha, A, lda, X, 1, beta, Y_mig, 1)
        block
            integer :: i
            type(real64x2) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max = real64x2(0.0_8); diff_max = real64x2(0.0_8)
            do i = 1, leny
                a_abs = abs(Y_mig(i)); if (a_abs > ref_max) ref_max = a_abs
                d_abs = abs(Y_ov(i) - Y_mig(i)); if (d_abs > diff_max) diff_max = d_abs
            end do
            tiny_val = real64x2(tiny(1.0_8))
            if (ref_max < tiny_val) then; err = diff_max; else; err = diff_max / ref_max; end if
        end block
        tol = max(real64x2(10.0_8), real64x2(4.0_8 * real(max(m, n), 8))) * eps
        if (err > tol) then
            fails = fails + 1
            print '(a,i0,a,a1,a,2i6)', 'FAIL ', ic, ' T=', trans, ' mn=', m, n
        end if
        deallocate(A, X, Y0, Y_ov, Y_mig)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_wgemv: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    if (fails > 0) error stop 1
end program
