#! Consistency fuzz — real IAMAX (1-based argmax of |x|). Returns integer.
program fuzz_${routine}$
    use fuzz_util
    implicit none
    interface
        function ${routine}$(n, x, incx) result(k)
            import :: rk
            integer, intent(in) :: n, incx
            real(rk), intent(in) :: x(*)
            integer :: k
        end function
        function ${routine}$_migrated(n, x, incx) result(k)
            import :: rk
            integer, intent(in) :: n, incx
            real(rk), intent(in) :: x(*)
            integer :: k
        end function
    end interface
    integer :: seed, ncases, ic, n, incx, lenx, fails
    integer :: k_ov, k_mig
    real(rk), allocatable :: X(:)
    seed = read_seed(); ncases = read_cases(); call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 4096); incx = rand_incx_pos()
        lenx = 1 + (n - 1) * abs(incx)
        allocate(X(lenx))
        call fill_matrix_real(X, lenx, 1, lenx)
        k_ov  = ${routine}$(n, X, incx)
        k_mig = ${routine}$_migrated(n, X, incx)
        if (k_ov /= k_mig) then
            fails = fails + 1
            call err_stats_record(1.0_rk)
            print '(a,i0,a,2i6,a,2i6)', 'FAIL ', ic, ' n,incx=', n, incx, ' got/exp=', k_ov, k_mig
        else
            call err_stats_record(0.0_rk)
        end if
        deallocate(X)
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
