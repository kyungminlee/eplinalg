#! Consistency fuzz driver — real SYR2K, parameterized by routine name.
#!
#! Per-target shim sets:
#!   routine    e.g. 'esyr2k' (kind10), 'qsyr2k' (kind16), 'msyr2k' (mf)
#!
#! Random N, K, UPLO ∈ {L, U}, TRANS ∈ {N, T}. Fills the non-UPLO
#! triangle of C with sentinels and verifies they stay untouched.
#! Tolerance: max(10, 8·K)·eps (twice the SYRK tolerance — SYR2K does
#! ~2× the work).

program fuzz_${routine}$
    use fuzz_util
    implicit none

    interface
        subroutine ${routine}$(uplo, trans, n, k, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: rk
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, lda, ldb, ldc
            real(rk), intent(in) :: alpha, beta
            real(rk), intent(in) :: a(lda, *), b(ldb, *)
            real(rk), intent(inout) :: c(ldc, *)
        end subroutine ${routine}$
        subroutine ${routine}$_migrated(uplo, trans, n, k, alpha, a, lda, b, ldb, beta, c, ldc)
            import :: rk
            character, intent(in) :: uplo, trans
            integer,   intent(in) :: n, k, lda, ldb, ldc
            real(rk), intent(in) :: alpha, beta
            real(rk), intent(in) :: a(lda, *), b(ldb, *)
            real(rk), intent(inout) :: c(ldc, *)
        end subroutine ${routine}$_migrated
    end interface

    integer :: seed, ncases, ic
    integer :: n, k, lda, ldb, ldc, rows_a, cols_a
    integer :: fails, sentinel_fails, bad_ov, bad_mig
    character :: uplo, trans
    real(rk) :: alpha, beta, err, tol
    real(rk), allocatable :: A(:), B(:), C0(:), C_ov(:), C_mig(:)
    real(8) :: u

    seed = read_seed()
    ncases = read_cases()
    call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed)

    fails = 0
    sentinel_fails = 0
    do ic = 1, ncases
        n = rand_int_log(1, 128)
        k = rand_int_log(1, 128)
        tol = max(10.0_rk, 8.0_rk * real(k, rk)) * eps
        call random_number(u)
        if (u < 0.5_8) then; uplo = 'L'; else; uplo = 'U'; end if
        call random_number(u)
        if (u < 0.5_8) then; trans = 'N'; else; trans = 'T'; end if
        call rand_alpha_beta(alpha, beta)

        if (trans == 'N') then; rows_a = n; cols_a = k
        else;                   rows_a = k; cols_a = n
        end if
        lda = rows_a + rand_pad()
        ldb = rows_a + rand_pad()
        ldc = n      + rand_pad()
        if (lda < 1) lda = 1
        if (ldb < 1) ldb = 1
        if (ldc < 1) ldc = 1

        allocate(A(lda * cols_a))
        allocate(B(ldb * cols_a))
        allocate(C0   (ldc * n))
        allocate(C_ov (ldc * n))
        allocate(C_mig(ldc * n))

        call fill_matrix_real(A,  rows_a, cols_a, lda)
        call fill_matrix_real(B,  rows_a, cols_a, ldb)
        call fill_matrix_real(C0, n,      n,      ldc)
        ! Stuff the non-UPLO triangle of C with sentinels: SYR2K must
        ! leave it untouched.
        block
            integer :: i, j, idx
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * ldc + i
                    if ((uplo == 'L' .and. i < j) .or. &
                        (uplo == 'U' .and. i > j)) then
                        C0(idx) = sentinel_re
                    end if
                end do
            end do
        end block
        C_ov  = C0
        C_mig = C0

        call ${routine}$(uplo, trans, n, k, alpha, A, lda, B, ldb, beta, C_ov,  ldc)
        call ${routine}$_migrated(uplo, trans, n, k, alpha, A, lda, B, ldb, beta, C_mig, ldc)

        ! Compare only the UPLO triangle.
        block
            integer :: i, j, idx
            real(rk) :: ref_max, diff_max, a_abs, d_abs, tiny_val
            ref_max  = 0.0_rk
            diff_max = 0.0_rk
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * ldc + i
                    if ((uplo == 'L' .and. i >= j) .or. &
                        (uplo == 'U' .and. i <= j)) then
                        a_abs = abs(C_mig(idx))
                        if (a_abs > ref_max) ref_max = a_abs
                        d_abs = abs(C_ov(idx) - C_mig(idx))
                        if (d_abs > diff_max) diff_max = d_abs
                    end if
                end do
            end do
            tiny_val = tiny(1.0_rk)
            if (ref_max < tiny_val) then; err = diff_max
            else;                          err = diff_max / ref_max
            end if
        end block
        bad_ov  = check_sentinels_real(C_ov,  n, n, ldc)
        bad_mig = check_sentinels_real(C_mig, n, n, ldc)
        ! Also check that the OTHER (non-UPLO) triangle still holds
        ! the sentinel — that's where we put it ourselves.
        block
            integer :: i, j, idx
            do j = 1, n
                do i = 1, n
                    idx = (j - 1) * ldc + i
                    if ((uplo == 'L' .and. i < j) .or. &
                        (uplo == 'U' .and. i > j)) then
                        if (C_ov(idx)  /= sentinel_re) bad_ov  = j
                        if (C_mig(idx) /= sentinel_re) bad_mig = j
                    end if
                end do
            end do
        end block

        call err_stats_record(err)

        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,2a1,a,2i6,a,3i6,a,es12.4,a,es12.4)', &
                'FAIL case ', ic, '  UT=', uplo, trans, &
                '  nk=', n, k, '  lda/ldb/ldc=', lda, ldb, ldc, &
                '  err=', err, '  tol=', tol
        end if
        if (bad_ov /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL overlay  case ', ic
        end if
        if (bad_mig /= 0) then
            sentinel_fails = sentinel_fails + 1
            print '(a,i0)', 'SENTINEL migrated case ', ic
        end if

        deallocate(A, B, C0, C_ov, C_mig)
    end do

    print '(a,i0,a,i0,a,i0,a,i0)', &
        'fuzz_${routine}$: ', ncases - fails, '/', ncases, &
        ' passed; tol_fails=', fails, ' sentinel_fails=', sentinel_fails

    call err_stats_print()
    if (fails > 0 .or. sentinel_fails > 0) error stop 1
end program fuzz_${routine}$
