#! Consistency fuzz — CABS1: returns |Re(z)| + |Im(z)|.
program fuzz_${routine}$
    use fuzz_util
    implicit none
    interface
        function ${routine}$(z) result(r)
            import :: rk
            complex(rk), intent(in) :: z
            real(rk) :: r
        end function
        function ${routine}$_migrated(z) result(r)
            import :: rk
            complex(rk), intent(in) :: z
            real(rk) :: r
        end function
    end interface
    integer :: seed, ncases, ic, fails
    complex(rk) :: z
    real(rk) :: r_ov, r_mig, err, tol
    real(8) :: ur, ui
    seed = read_seed(); ncases = read_cases(); call err_stats_init(ncases)
    print '(a,i0,a,i0)', 'fuzz_${routine}$: seed=', seed, '  cases=', ncases
    call seed_rng(seed); fails = 0
    do ic = 1, ncases
        call random_number(ur); call random_number(ui)
        z = cmplx(real(2.0_8*ur-1.0_8, rk), real(2.0_8*ui-1.0_8, rk), rk)
        r_ov  = ${routine}$(z)
        r_mig = ${routine}$_migrated(z)
        if (abs(r_mig) < tiny(1.0_rk)) then; err = abs(r_ov - r_mig)
        else; err = abs(r_ov - r_mig) / abs(r_mig); end if
        tol = 10.0_rk * eps
        call err_stats_record(err)
        if (err > tol .or. err /= err) then
            fails = fails + 1
            print '(a,i0,a,es12.4)', 'FAIL ', ic, ' err=', err
        end if
    end do
    print '(a,i0,a,i0,a,i0)', 'fuzz_${routine}$: ', ncases - fails, '/', ncases, ' passed; tol_fails=', fails
    call err_stats_print()
    if (fails > 0) error stop 1
end program
